@* Components/UserApplications/UserApplications.razor *@
@using dto.user.Models
@inject IUserService UserService
@inject IApplicationService ApplicationService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<UserApplications> Logger

@if (!string.IsNullOrEmpty(errorMessage))
{
    <MudAlert Severity="Severity.Error" ShowCloseIcon="true"
              CloseIconClicked="() => errorMessage = null"
              Class="mb-4">
        @errorMessage
    </MudAlert>
}

<!-- Applications assignées -->
<MudPaper Elevation="2" Class="mb-4" Style="overflow: hidden;">
    <div style="background: var(--mud-palette-primary); padding: 0.75rem 1rem;">
        <MudText Typo="Typo.body1" Style="color: white; font-weight: 500;">
            <MudIcon Icon="@Icons.Material.Filled.Apps" Class="me-2" Size="Size.Small" />
            Applications assignées
        </MudText>
    </div>

    @if (isLoadingAssignments)
    {
        <div class="d-flex justify-content-center pa-4">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
            <MudText Class="ms-3" Color="Color.Secondary">Chargement...</MudText>
        </div>
    }
    else if (!userApplications.Any())
    {
        <MudText Class="pa-4" Color="Color.Secondary">
            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="me-1" />
            Aucune application assignée
        </MudText>
    }
    else
    {
        @foreach (var userApp in userApplications)
        {
            <MudDivider />
            <div class="d-flex justify-content-between align-items-center px-4 py-3">
                <div>
                    <MudText Typo="Typo.body1" Style="font-weight: 500;">
                        <MudIcon Icon="@Icons.Material.Filled.AppShortcut"
                                 Color="Color.Primary"
                                 Size="Size.Small"
                                 Class="me-2" />
                        @userApp.ApplicationName
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Assignée le @userApp.GrantedAt.ToString("dd/MM/yyyy HH:mm")
                    </MudText>
                </div>
                <MudTooltip Text="Retirer cette application">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   Disabled="@(isLoadingAction && actionApplicationId == userApp.ApplicationId)"
                                   OnClick="@(() => ConfirmRemoveApplication(userApp))" />
                </MudTooltip>
            </div>
        }
    }
</MudPaper>

<!-- Ajouter une application -->
<MudPaper Elevation="2" Style="overflow: hidden;">
    <div style="background: var(--mud-palette-success); padding: 0.75rem 1rem;">
        <MudText Typo="Typo.body1" Style="color: white; font-weight: 500;">
            <MudIcon Icon="@Icons.Material.Filled.AddCircle" Class="me-2" Size="Size.Small" />
            Ajouter une application
        </MudText>
    </div>

    <div class="pa-4">
        @if (isLoadingAvailable)
        {
            <div class="d-flex align-items-center">
                <MudProgressCircular Color="Color.Success" Indeterminate="true" Size="Size.Small" />
                <MudText Class="ms-3" Color="Color.Secondary">Chargement...</MudText>
            </div>
        }
        else if (!availableApplications.Any())
        {
            <MudText Color="Color.Secondary">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                         Color="Color.Success"
                         Size="Size.Small"
                         Class="me-1" />
                Toutes les applications sont déjà assignées
            </MudText>
        }
        else
        {
            <div class="d-flex gap-3 align-items-center">
                <MudSelect T="int"
                           @bind-Value="selectedApplicationId"
                           Label="Sélectionner une application"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Disabled="@isLoadingAction"
                           Style="flex: 1;">
                    <MudSelectItem Value="0">-- Choisir --</MudSelectItem>
                    @foreach (var app in availableApplications)
                    {
                        <MudSelectItem Value="@app.Id">@app.Name</MudSelectItem>
                    }
                </MudSelect>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Add"
                           Disabled="@(isLoadingAction || selectedApplicationId == 0)"
                           OnClick="AddApplication">
                    @if (isLoadingAction && selectedApplicationId != 0)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-1" />
                    }
                    Ajouter
                </MudButton>
            </div>
        }
    </div>
</MudPaper>

@code {
    [Parameter] public int UserId { get; set; }
    [Parameter] public EventCallback OnApplicationsChanged { get; set; }

    private List<UserApplicationDto> userApplications = new();
    private List<ApplicationDto> availableApplications = new();
    private int selectedApplicationId = 0;
    private int actionApplicationId = 0;

    private bool isLoadingAssignments = false;
    private bool isLoadingAvailable = false;
    private bool isLoadingAction = false;

    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        if (UserId > 0)
        {
            await LoadUserApplications();
            await LoadAvailableApplications();
        }
    }

    private async Task LoadUserApplications()
    {
        isLoadingAssignments = true;
        errorMessage = null;
        try
        {
            var result = await UserService.GetUserApplications(UserId);
            if (result.Success && result.Data != null)
                userApplications = result.Data;
            else
                errorMessage = result.ErrorMessage ?? "Impossible de charger les applications";
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur lors du chargement des applications";
            Logger.LogError(ex, "Error loading applications for user {UserId}", UserId);
        }
        finally
        {
            isLoadingAssignments = false;
        }
    }

    private async Task LoadAvailableApplications()
    {
        isLoadingAvailable = true;
        try
        {
            var result = await ApplicationService.GetAllApplications();
            if (result.Success && result.Data != null)
            {
                var assignedIds = userApplications.Select(ua => ua.ApplicationId).ToHashSet();
                availableApplications = result.Data.Where(a => !assignedIds.Contains(a.Id)).ToList();
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Impossible de charger les applications disponibles";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur lors du chargement des applications disponibles";
            Logger.LogError(ex, "Error loading available applications");
        }
        finally
        {
            isLoadingAvailable = false;
        }
    }

    private async Task AddApplication()
    {
        if (selectedApplicationId == 0) return;

        isLoadingAction = true;
        errorMessage = null;
        try
        {
            var request = new AssignApplicationRequest
            {
                UserId        = UserId,
                ApplicationId = selectedApplicationId
            };

            var result = await UserService.AssignApplication(request);

            if (result.Success && result.Data != null)
            {
                var appName = availableApplications.First(a => a.Id == selectedApplicationId).Name;
                Snackbar.Add($"Application '{appName}' assignée avec succès", Severity.Success);
                selectedApplicationId = 0;
                await LoadUserApplications();
                await LoadAvailableApplications();
                await OnApplicationsChanged.InvokeAsync();
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Impossible d'assigner l'application";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur lors de l'assignation";
            Logger.LogError(ex, "Error assigning application {AppId} to user {UserId}", selectedApplicationId, UserId);
        }
        finally
        {
            isLoadingAction = false;
        }
    }

    private async Task ConfirmRemoveApplication(UserApplicationDto userApp)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Confirmer la suppression",
            $"Retirer l'application '{userApp.ApplicationName}' de cet utilisateur ?",
            yesText: "Retirer",
            cancelText: "Annuler");

        if (result == true)
            await RemoveApplication(userApp.ApplicationId, userApp.ApplicationName);
    }

    private async Task RemoveApplication(int applicationId, string applicationName)
    {
        isLoadingAction = true;
        actionApplicationId = applicationId;
        errorMessage = null;
        try
        {
            var request = new RemoveApplicationRequest
            {
                UserId        = UserId,
                ApplicationId = applicationId
            };

            var result = await UserService.RemoveApplication(request);

            if (result.Success)
            {
                Snackbar.Add($"Application '{applicationName}' retirée", Severity.Info);
                await LoadUserApplications();
                await LoadAvailableApplications();
                await OnApplicationsChanged.InvokeAsync();
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Impossible de retirer l'application";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur lors de la suppression";
            Logger.LogError(ex, "Error removing application {AppId} from user {UserId}", applicationId, UserId);
        }
        finally
        {
            isLoadingAction = false;
            actionApplicationId = 0;
        }
    }
}