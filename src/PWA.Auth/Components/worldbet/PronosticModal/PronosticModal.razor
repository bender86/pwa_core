@* Components/WorldBet/PronosticModal/PronosticModal.razor *@
@namespace PWA.Auth.Components.worldbet.PronosticModal
@using dto.worldbet.Models
@using dto.worldbet.Requests
@inject IPronosticService PronosticService
@inject ILogger<PronosticModal> Logger

<MudDialog>
    <DialogContent>
        <div class="pa-4">
            <!-- Match Info -->
            <MudPaper Elevation="0" Class="match-header mb-4 pa-4">
                <div class="text-center mb-2">
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary">@Match.PhaseName</MudChip>
                    @if (!string.IsNullOrEmpty(Match.GroupLetter))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ms-1">Groupe @Match.GroupLetter</MudChip>
                    }
                </div>
                
                
                <div class="match-teams">
                    <div class="team-block">
                        @if (!string.IsNullOrEmpty(Match.FlagUrlTeam1))
                        {
                            <MudImage Src="@Match.FlagUrlTeam1"
                                    Alt="@Match.Team1Name"
                                    Width="40" Height="27"
                                    ObjectFit="ObjectFit.Cover"
                                    Style="border-radius: 3px; border: 1px solid rgba(255,255,255,0.3);" />
                        }
                        <MudText Typo="Typo.h6" Class="white-text">@Match.Team1Name</MudText>
                    </div>

                    <MudText Typo="Typo.h5" Class="white-text mx-3">VS</MudText>

                    <div class="team-block">
                        @if (!string.IsNullOrEmpty(Match.FlagUrlTeam2))
                        {
                            <MudImage Src="@Match.FlagUrlTeam2"
                                    Alt="@Match.Team2Name"
                                    Width="40" Height="27"
                                    ObjectFit="ObjectFit.Cover"
                                    Style="border-radius: 3px; border: 1px solid rgba(255,255,255,0.3);" />
                        }
                        <MudText Typo="Typo.h6" Class="white-text">@Match.Team2Name</MudText>
                    </div>
                </div>
                
                <div class="text-center mt-3">
                    <MudText Typo="Typo.body2" Class="white-text">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" />
                        @Match.ScheduledDate.ToString("dd/MM/yyyy HH:mm")
                    </MudText>
                    <MudText Typo="Typo.body2" Class="white-text">
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" />
                        Fermeture : @Match.LockPronosticsAt.ToString("dd/MM HH:mm")
                    </MudText>
                </div>
            </MudPaper>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">
                    @errorMessage
                </MudAlert>
            }

            <!-- Score Input -->
            <MudPaper Elevation="0" Class="pronostic-input pa-4">
                <div class="score-container">
                    <div class="score-team">
                        <MudText Typo="Typo.body2" Class="mb-2">@Match.Team1Name</MudText>
                        <MudNumericField @bind-Value="team1Score"
                                        Min="0"
                                        Max="20"
                                        Variant="Variant.Outlined"
                                        Class="score-input-field" />
                    </div>
                    <MudText Typo="Typo.h4" Class="score-separator">-</MudText>
                    <div class="score-team">
                        <MudText Typo="Typo.body2" Class="mb-2">@Match.Team2Name</MudText>
                        <MudNumericField @bind-Value="team2Score"
                                        Min="0"
                                        Max="20"
                                        Variant="Variant.Outlined"
                                        Class="score-input-field" />
                    </div>
                </div>
            </MudPaper>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" 
                   Color="Color.Secondary"
                   Variant="Variant.Text"
                   Disabled="@isSaving">
            Annuler
        </MudButton>
        <MudButton OnClick="SavePronostic" 
                   Color="Color.Success"
                   Variant="Variant.Filled"
                   Disabled="@isSaving"
                   StartIcon="@Icons.Material.Filled.Bolt">
            @if (isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <span>Valider</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public MatchDto Match { get; set; } = null!;
    [Parameter] public EventCallback<PronosticDto> OnSaved { get; set; }
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private int? team1Score;
    private int? team2Score;
    private bool isSaving = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadExistingPronostic();
    }

    private async Task LoadExistingPronostic()
    {
        try
        {
            var existing = await PronosticService.GetMyPronosticForMatchAsync(Match.MatchId);
            if (existing != null)
            {
                team1Score = existing.PredictedScoreTeam1;
                team2Score = existing.PredictedScoreTeam2;
            }
            else
            {
                team1Score = null;
                team2Score = null;
            }
        }
        catch
        {
            team1Score = null;
            team2Score = null;
        }
    }

    private async Task SavePronostic()
    {
        if (!team1Score.HasValue || !team2Score.HasValue)
        {
            errorMessage = "Veuillez saisir les deux scores.";
            return;
        }

        if (team1Score < 0 || team1Score > 20 || team2Score < 0 || team2Score > 20)
        {
            errorMessage = "Les scores doivent être entre 0 et 20.";
            return;
        }

        isSaving = true;
        errorMessage = null;

        try
        {
            var request = new CreatePronosticRequest
            {
                MatchId = Match.MatchId,
                PredictedScoreTeam1 = team1Score.Value,
                PredictedScoreTeam2 = team2Score.Value
            };

            var saved = await PronosticService.CreateOrUpdatePronosticAsync(request);
            await OnSaved.InvokeAsync(saved);
            MudDialog.Close(DialogResult.Ok(saved)); // ferme et passe le résultat au parent
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
            Logger.LogError(ex, "Error saving pronostic");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Close()
    {
        MudDialog.Cancel();
    }
}

<style>
    .match-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white !important;
        border-radius: 8px;
    }

    .white-text {
        color: white !important;
    }

    .match-teams {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        margin: 1rem 0;
    }

    .pronostic-input {
        background: #f8f9fa;
        border-radius: 8px;
    }

    .score-container {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 2rem;
    }

    .score-team {
        flex: 1;
        text-align: center;
    }

    .score-separator {
        color: #6c757d;
        padding-top: 1.5rem;
    }

    @@media (max-width: 768px) {
        .score-container {
            flex-direction: column;
            gap: 1rem;
        }

        .score-separator {
            display: none;
        }
    }
    .team-block {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
    }
</style>