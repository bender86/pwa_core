@* Components/WorldBet/MatchCard/MatchCard.razor *@
@namespace PWA.Auth.Components.worldbet.MatchCard
@using dto.worldbet.Models
@using dto.worldbet.Enums

<div class="card mb-3 shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h6 class="card-subtitle text-muted mb-0">@Match.PhaseName - @(Match.GroupLetter ?? "")</h6>
            <span class="badge @GetStatusBadgeClass()">@GetStatusText()</span>
        </div>

        <div class="row align-items-center my-3">
            <div class="col-5 text-center">
                <strong>@Match.Team1Name</strong>
                @if (Match.ScoreTeam1.HasValue)
                {
                    <div class="display-6 fw-bold text-primary mt-2">@Match.ScoreTeam1</div>
                }
            </div>

            <div class="col-2 text-center">
                <div class="fw-bold text-muted">VS</div>
            </div>

            <div class="col-5 text-center">
                <strong>@Match.Team2Name</strong>
                @if (Match.ScoreTeam2.HasValue)
                {
                    <div class="display-6 fw-bold text-primary mt-2">@Match.ScoreTeam2</div>
                }
            </div>
        </div>

        <div class="text-center mb-2">
            <small class="text-muted">
                <i class="bi bi-calendar-event"></i> @Match.ScheduledDate.ToString("dd/MM/yyyy HH:mm")
            </small>
        </div>

        <div class="text-center mb-3">
            <small class="text-muted">
                <i class="bi bi-lock"></i> Verrouillage : @Match.LockPronosticsAt.ToString("dd/MM/yyyy HH:mm")
            </small>
        </div>

        @if (HasPronostic && UserPronostic != null)
        {
            <div class="alert alert-info mb-3">
                <div class="row text-center">
                    <div class="col-5">
                        <strong>Votre pronostic</strong>
                        <div class="display-6">@UserPronostic.PredictedScoreTeam1</div>
                    </div>
                    <div class="col-2">
                        <div class="mt-3">-</div>
                    </div>
                    <div class="col-5">
                        <strong>&nbsp;</strong>
                        <div class="display-6">@UserPronostic.PredictedScoreTeam2</div>
                    </div>
                </div>
                @if (UserPronostic.PointsEarned >= 0)
                {
                    <div class="text-center mt-2">
                        <span class="badge bg-success">+@UserPronostic.PointsEarned points</span>
                    </div>
                }
            </div>
        }

        @* Boutons d'action *@
        <div class="d-flex justify-content-center gap-2">
            @* Bouton Voir les pronostics (seulement pour matches terminés ou en cours) *@
            @if (Match.Status == MatchStatus.Live || Match.Status == MatchStatus.Finished)
            {
                <ViewPronosticsButton 
                    MatchId="@Match.MatchId"
                    Status="@Match.Status"
                    ButtonText="Voir les pronos" />
            }
            
            @* Bouton pour faire un pronostic *@
            <PronosticButton Match="@Match" 
                           HasPronostic="@HasPronostic" 
                           OnPronosticSaved="@HandlePronosticSaved"
                           OnModalOpened="@NotifyModalOpened"
                           OnModalClosed="@NotifyModalClosed"
                           Size="Small" />
        </div>
    </div>
</div>

@code {
    [Parameter]
    public MatchDto Match { get; set; } = null!;

    [Parameter]
    public bool HasPronostic { get; set; }

    [Parameter]
    public PronosticDto? UserPronostic { get; set; }

    [Parameter]
    public EventCallback<PronosticDto> OnPronosticSaved { get; set; }

    [Parameter]
    public EventCallback OnPronosticModalOpened { get; set; }

    [Parameter]
    public EventCallback OnPronosticModalClosed { get; set; }

    private async Task HandlePronosticSaved(PronosticDto prono)
    {
        if (OnPronosticSaved.HasDelegate)
        {
            await OnPronosticSaved.InvokeAsync(prono);
        }
    }

    private async Task NotifyModalOpened()
    {
        if (OnPronosticModalOpened.HasDelegate)
        {
            await OnPronosticModalOpened.InvokeAsync();
        }
    }

    private async Task NotifyModalClosed()
    {
        if (OnPronosticModalClosed.HasDelegate)
        {
            await OnPronosticModalClosed.InvokeAsync();
        }
    }

    private string GetStatusBadgeClass()
    {
        if (Match.ScoreTeam1.HasValue && Match.ScoreTeam2.HasValue)
            return "bg-secondary";

        if (!CanPronostic())
            return "bg-warning";

        return "bg-success";
    }

    private string GetStatusText()
    {
        if (Match.ScoreTeam1.HasValue && Match.ScoreTeam2.HasValue)
            return "Terminé";

        if (!CanPronostic())
            return "Verrouillé";

        return "Pending";
    }

    private bool CanPronostic()
    {
        return Match.Status == MatchStatus.Scheduled 
            && DateTime.UtcNow < Match.LockPronosticsAt;
    }
}

<style>
    .team-flag {
        width: 48px;
        height: 32px;
        object-fit: contain;
        border: 1px solid #dee2e6;
        border-radius: 4px;
    }
</style>