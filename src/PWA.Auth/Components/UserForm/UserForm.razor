@* Components/UserForm/UserForm.razor *@
@using dto.common.Enums
@using dto.user.Enums
@using dto.user.Models
@using PWA.Auth.Models

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <MudAlert Severity="Severity.Error" ShowCloseIcon="true"
              CloseIconClicked="() => ErrorMessage = null"
              Class="mb-4">
        @ErrorMessage
    </MudAlert>
}

<MudForm @ref="form" @bind-IsValid="isValid">
    <MudGrid Spacing="3">

        <!-- Prénom -->
        <MudItem xs="12" sm="6">
            <MudTextField T="string"
                          @bind-Value="model.FirstName"
                          Label="Prénom"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="Le prénom est requis"
                          Disabled="@IsLoading"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person" />
        </MudItem>

        <!-- Nom -->
        <MudItem xs="12" sm="6">
            <MudTextField T="string"
                          @bind-Value="model.LastName"
                          Label="Nom"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="Le nom est requis"
                          Disabled="@IsLoading"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person" />
        </MudItem>

        <!-- Email -->
        <MudItem xs="12">
            <MudTextField T="string"
                          @bind-Value="model.Email"
                          Label="Email"
                          InputType="InputType.Email"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="L'email est requis"
                          Disabled="@(IsLoading || Mode == FormMode.Edit)"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email"
                          HelperText="@(Mode == FormMode.Create && !RequirePassword ? "Un email d'invitation sera envoyé à cette adresse" : null)" />
        </MudItem>

        <!-- Mot de passe (seulement si requis en création) -->
        @if (RequirePassword && Mode == FormMode.Create)
        {
            <MudItem xs="12">
                <MudTextField T="string"
                              @bind-Value="model.Password"
                              Label="Mot de passe"
                              InputType="@passwordInputType"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="Le mot de passe est requis"
                              Disabled="@IsLoading"
                              Adornment="Adornment.End"
                              AdornmentIcon="@passwordIcon"
                              OnAdornmentClick="TogglePasswordVisibility" />
            </MudItem>
        }

        <!-- Options Admin -->
        @if (ShowAdminOptions)
        {
            <MudItem xs="12">
                <MudPaper Elevation="0" Class="pa-4"
                          Style="border: 1px solid var(--mud-palette-divider); border-radius: 8px;">
                    <MudText Typo="Typo.body1" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Class="me-2" />
                        Options administrateur
                    </MudText>
                    <MudSwitch @bind-Value="model.IsAdmin"
                               Color="Color.Primary"
                               Label="Administrateur"
                               Disabled="@IsLoading"
                               Class="mb-2" />
                    <MudSwitch @bind-Value="model.Active"
                               Color="Color.Success"
                               Label="Compte actif"
                               Disabled="@IsLoading" />
                </MudPaper>
            </MudItem>
        }

    </MudGrid>

    <!-- Boutons d'action -->
    <div class="d-flex gap-2 mt-4">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@(Mode == FormMode.Create ? Icons.Material.Filled.PersonAdd : Icons.Material.Filled.Save)"
                   Disabled="@(!isValid || IsLoading)"
                   OnClick="HandleSubmit">
            @if (IsLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                <span>Enregistrement...</span>
            }
            else
            {
                @(Mode == FormMode.Create ? "Créer l'utilisateur" : "Mettre à jour")
            }
        </MudButton>

        @if (ShowCancelButton)
        {
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.Close"
                       Disabled="@IsLoading"
                       OnClick="OnCancel">
                Annuler
            </MudButton>
        }
    </div>
</MudForm>

@code {
    [Parameter] public FormMode Mode { get; set; }
    [Parameter] public UserFormModel? InitialData { get; set; }
    [Parameter] public EventCallback<UserFormModel> OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public bool ShowAdminOptions { get; set; } = false;
    [Parameter] public bool ShowCancelButton { get; set; } = true;
    [Parameter] public bool RequirePassword { get; set; } = false;

    private MudForm? form;
    private bool isValid;
    private bool showPassword = false;
    private UserFormModel model = new();

    private InputType passwordInputType => showPassword ? InputType.Text : InputType.Password;
    private string passwordIcon => showPassword
        ? Icons.Material.Filled.VisibilityOff
        : Icons.Material.Filled.Visibility;

    private void TogglePasswordVisibility() => showPassword = !showPassword;

    protected override void OnParametersSet()
    {
        model = InitialData != null
            ? new UserFormModel
            {
                Id         = InitialData.Id,
                FirstName  = InitialData.FirstName,
                LastName   = InitialData.LastName,
                Email      = InitialData.Email,
                Password   = InitialData.Password,
                IsAdmin    = InitialData.IsAdmin,
                Active     = InitialData.Active,
                MfaEnabled = InitialData.MfaEnabled
            }
            : new UserFormModel { Active = true };
    }

    private async Task HandleSubmit()
    {
        if (form != null)
        {
            await form.Validate();
            if (isValid)
                await OnSubmit.InvokeAsync(model);
        }
    }
}