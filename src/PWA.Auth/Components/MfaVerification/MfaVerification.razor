@* Components/MfaVerification/MfaVerification.razor *@

@if (ShowQrCode && !string.IsNullOrEmpty(QrCodeBase64))
{
    <div class="text-center mb-4">
        <MudText Typo="Typo.h6" Class="mb-1">
            <MudIcon Icon="@Icons.Material.Filled.QrCode2" Class="me-2" />
            Scannez le QR code
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Utilisez Google Authenticator ou une application similaire
        </MudText>
        <img src="@QrCodeBase64" alt="QR Code" style="width: 60%; border-radius: 8px;" />

        @if (!string.IsNullOrEmpty(SecretKey))
        {
            <div class="mt-3">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Clé manuelle :</MudText>
                <MudPaper Elevation="0" Class="pa-2 mt-1"
                          Style="background: var(--mud-palette-background-grey); border-radius: 6px;">
                    <code style="font-size: 0.85rem; word-break: break-all;">@SecretKey</code>
                </MudPaper>
            </div>
        }
    </div>

    <MudDivider Class="mb-4" />
}

@* Header *@
<div class="text-center mb-4">
    @if (!ShowQrCode)
    {
        <MudIcon Icon="@Icons.Material.Filled.PhonelinkLock"
                 Color="Color.Primary"
                 Style="font-size: 3rem;" />
        <MudText Typo="Typo.h6" Class="mt-2 mb-1">Code d'authentification</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Ouvrez votre application et entrez le code à 6 chiffres
        </MudText>
    }
    else
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">@PromptMessage</MudText>
    }
</div>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <MudAlert Severity="Severity.Error" Class="mb-3">@ErrorMessage</MudAlert>
}

<MudTextField T="string"
              @bind-Value="code"
              Label="Code à 6 chiffres"
              Variant="Variant.Outlined"
              MaxLength="6"
              Placeholder="123456"
              InputType="InputType.Number"
              Adornment="Adornment.Start"
              AdornmentIcon="@Icons.Material.Filled.Key"
              Disabled="@IsLoading"
              @onkeyup="HandleKeyUp"
              Class="mb-4"
              Style="text-align: center; letter-spacing: 0.5rem;" />

<MudButton Variant="Variant.Filled"
           Color="Color.Primary"
           FullWidth="true"
           Size="Size.Large"
           Disabled="@(IsLoading || code.Length != 6)"
           OnClick="SubmitCode"
           Class="mb-2">
    @if (IsLoading)
    {
        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
        <span>Vérification...</span>
    }
    else
    {
        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Class="me-2" />
        <span>Vérifier</span>
    }
</MudButton>

@if (ShowCancelButton)
{
    <MudButton Variant="Variant.Text"
               Color="Color.Default"
               FullWidth="true"
               Disabled="@IsLoading"
               OnClick="Cancel">
        Annuler
    </MudButton>
}

@code {
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public bool ShowQrCode { get; set; } = false;
    [Parameter] public string? QrCodeBase64 { get; set; }
    [Parameter] public string? SecretKey { get; set; }
    [Parameter] public bool ShowCancelButton { get; set; } = true;
    [Parameter] public string PromptMessage { get; set; } = "Entrez votre code d'authentification à deux facteurs";
    [Parameter] public EventCallback<string> OnMfaCodeSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private string code = "";

    private async Task SubmitCode()
    {
        if (string.IsNullOrEmpty(code) || code.Length != 6) return;
        await OnMfaCodeSubmit.InvokeAsync(code);
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && code.Length == 6)
            _ = SubmitCode();
    }

    private async Task Cancel()
    {
        code = "";
        await OnCancel.InvokeAsync();
    }
}