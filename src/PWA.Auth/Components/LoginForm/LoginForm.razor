@* Components/LoginForm/LoginForm.razor *@
@using dto.auth.Models

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@ErrorMessage</MudAlert>
}

<MudForm @ref="form" @bind-IsValid="isValid">
    <MudTextField T="string"
                  @bind-Value="model.Email"
                  Label="Email / Nom d'utilisateur"
                  Variant="Variant.Outlined"
                  Required="true"
                  RequiredError="L'email est requis"
                  Disabled="@IsLoading"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Person"
                  Class="mb-3" />

    <MudTextField T="string"
                  @bind-Value="model.Password"
                  Label="Mot de passe"
                  InputType="@passwordInputType"
                  Variant="Variant.Outlined"
                  Required="true"
                  RequiredError="Le mot de passe est requis"
                  Disabled="@IsLoading"
                  Adornment="Adornment.End"
                  AdornmentIcon="@passwordIcon"
                  OnAdornmentClick="TogglePasswordVisibility"
                  Class="mb-2" />

    <div class="d-flex justify-content-end mb-4">
        <MudLink Href="/forgot-password" Typo="Typo.body2">
            Mot de passe oublié ?
        </MudLink>
    </div>

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               FullWidth="true"
               Size="Size.Large"
               Disabled="@(!isValid || IsLoading)"
               OnClick="HandleSubmit">
        @if (IsLoading)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            <span>Connexion...</span>
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.Login" Class="me-2" />
            <span>Se connecter</span>
        }
    </MudButton>
</MudForm>

@code {
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public EventCallback<AuthenticateRequest> OnLoginSubmit { get; set; }

    private MudForm? form;
    private bool isValid;
    private bool showPassword = false;

    private InputType passwordInputType => showPassword ? InputType.Text : InputType.Password;
    private string passwordIcon => showPassword
        ? Icons.Material.Filled.VisibilityOff
        : Icons.Material.Filled.Visibility;

    private void TogglePasswordVisibility() => showPassword = !showPassword;

    private AuthenticateRequest model = new()
    {
        Email    = string.Empty,
        Password = string.Empty
    };

    private async Task HandleSubmit()
    {
        if (form != null)
        {
            await form.Validate();
            if (isValid)
                await OnLoginSubmit.InvokeAsync(model);
        }
    }
}