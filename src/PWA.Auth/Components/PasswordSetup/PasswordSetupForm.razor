@* Components/PasswordSetup/PasswordSetupForm.razor *@
@using System.ComponentModel.DataAnnotations

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@ErrorMessage</MudAlert>
}

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <MudAlert Severity="Severity.Success" Class="mb-4">@SuccessMessage</MudAlert>
}

@if (!IsSuccess)
{
    @if (!string.IsNullOrEmpty(Title))
    {
        <div class="text-center mb-4">
            @if (!string.IsNullOrEmpty(IconClass))
            {
                <i class="@IconClass" style="font-size: 3rem; color: var(--mud-palette-primary);"></i>
            }
            <MudText Typo="Typo.h5" Class="mt-3">@Title</MudText>
            @if (!string.IsNullOrEmpty(Description))
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">@Description</MudText>
            }
        </div>
    }

    <MudForm @ref="form" @bind-IsValid="isValid">
        <MudTextField T="string"
                      @bind-Value="model.Password"
                      Label="Mot de passe"
                      InputType="@passwordInputType"
                      Variant="Variant.Outlined"
                      Required="true"
                      RequiredError="Le mot de passe est requis"
                      Validation="@(new Func<string, string?>(ValidatePassword))"
                      Disabled="@IsLoading"
                      Adornment="Adornment.End"
                      AdornmentIcon="@passwordIcon"
                      OnAdornmentClick="TogglePasswordVisibility"
                      HelperText="Minimum 8 caractères"
                      Class="mb-3" />

        <MudTextField T="string"
                      @bind-Value="model.ConfirmPassword"
                      Label="Confirmer le mot de passe"
                      InputType="@confirmInputType"
                      Variant="Variant.Outlined"
                      Required="true"
                      RequiredError="La confirmation est requise"
                      Validation="@(new Func<string, string?>(ValidateConfirmPassword))"
                      Disabled="@IsLoading"
                      Adornment="Adornment.End"
                      AdornmentIcon="@confirmIcon"
                      OnAdornmentClick="ToggleConfirmVisibility"
                      Class="mb-4" />

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   Size="Size.Large"
                   Disabled="@(!isValid || IsLoading)"
                   OnClick="HandleSubmit">
            @if (IsLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                @LoadingText
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.Check" Class="me-2" />
                @SubmitButtonText
            }
        </MudButton>
    </MudForm>
}

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? IconClass { get; set; }
    [Parameter] public string SubmitButtonText { get; set; } = "Valider";
    [Parameter] public string LoadingText { get; set; } = "Traitement en cours...";
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool IsSuccess { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter] public string? SuccessMessage { get; set; }
    [Parameter] public EventCallback<PasswordSetupModel> OnSubmit { get; set; }

    private MudForm? form;
    private bool isValid;
    private PasswordSetupModel model = new();

    // Password visibility
    private bool showPassword = false;
    private bool showConfirm = false;

    private InputType passwordInputType => showPassword ? InputType.Text : InputType.Password;
    private InputType confirmInputType  => showConfirm  ? InputType.Text : InputType.Password;
    private string passwordIcon => showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    private string confirmIcon  => showConfirm  ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    private void TogglePasswordVisibility() => showPassword = !showPassword;
    private void ToggleConfirmVisibility()  => showConfirm  = !showConfirm;

    private string? ValidatePassword(string value)
    {
        if (string.IsNullOrEmpty(value)) return "Le mot de passe est requis";
        if (value.Length < 8) return "Minimum 8 caractères";
        return null;
    }

    private string? ValidateConfirmPassword(string value)
    {
        if (string.IsNullOrEmpty(value)) return "La confirmation est requise";
        if (value != model.Password) return "Les mots de passe ne correspondent pas";
        return null;
    }

    private async Task HandleSubmit()
    {
        if (form != null)
        {
            await form.Validate();
            if (isValid)
                await OnSubmit.InvokeAsync(model);
        }
    }

    public class PasswordSetupModel
    {
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}