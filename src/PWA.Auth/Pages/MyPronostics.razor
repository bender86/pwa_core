@page "/worldbet/my-pronostics"
@using PWA.Auth.Pages.WorldBet.Shared
@using dto.worldbet.Models
@using dto.worldbet.Enums
@layout WorldBetLayout
@inject IPronosticService PronosticService
@inject ITournamentService TournamentService
@inject ISnackbar Snackbar
@attribute [Authorize]

<PageTitle>Mes Pronostics</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <!-- Page Header -->
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Bolt" Class="me-2" />
        Mes Pronostics
    </MudText>

    @if (isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }
    else
    {
        <!-- Statistics Cards -->
        <MudGrid Class="mb-4">
            <MudItem xs="6" sm="3">
                <MudPaper Elevation="2" Class="pa-4">
                    <div class="d-flex align-items-center">
                        <MudAvatar Color="Color.Primary" Size="Size.Large" Class="me-3">
                            <MudIcon Icon="@Icons.Material.Filled.Bolt" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.h4">@pronostics.Count</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Pronostics</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="6" sm="3">
                <MudPaper Elevation="2" Class="pa-4">
                    <div class="d-flex align-items-center">
                        <MudAvatar Color="Color.Success" Size="Size.Large" Class="me-3">
                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.h4">@totalPoints</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Points</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="6" sm="3">
                <MudPaper Elevation="2" Class="pa-4">
                    <div class="d-flex align-items-center">
                        <MudAvatar Color="Color.Info" Size="Size.Large" Class="me-3">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.h4">@exactScores</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Scores exacts</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="6" sm="3">
                <MudPaper Elevation="2" Class="pa-4">
                    <div class="d-flex align-items-center">
                        <MudAvatar Color="Color.Warning" Size="Size.Large" Class="me-3">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.h4">@pendingCount</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">En attente</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Filters -->
        <MudPaper Class="pa-4 mb-4" Elevation="2">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4">
                    <MudSelect T="string" 
                               @bind-Value="filterStatus"
                               Label="Statut" 
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               AdornmentIcon="@Icons.Material.Filled.FilterList">
                        <MudSelectItem Value="@("")">Tous les statuts</MudSelectItem>
                        <MudSelectItem Value="@("pending")">En attente</MudSelectItem>
                        <MudSelectItem Value="@("correct")">Gagnés</MudSelectItem>
                        <MudSelectItem Value="@("incorrect")">Perdus</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudSelect T="string" 
                               @bind-Value="filterPhase"
                               Label="Phase" 
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               AdornmentIcon="@Icons.Material.Filled.Stadium">
                        <MudSelectItem Value="@("")">Toutes les phases</MudSelectItem>
                        @foreach (var phase in uniquePhases)
                        {
                            <MudSelectItem Value="@phase">@phase</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="4" Class="d-flex align-items-center">
                    <MudSwitch @bind-Value="showOnlyWithPoints" 
                              Color="Color.Primary"
                              Label="Seulement avec points" />
                </MudItem>
            </MudGrid>
        </MudPaper>

        <!-- Pronostics Grid -->
        @if (!filteredPronostics.Any())
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">
                @if (filterStatus != "" || filterPhase != "" || showOnlyWithPoints)
                {
                    <span>Aucun pronostic ne correspond à ces critères.</span>
                }
                else
                {
                    <span>Vous n'avez pas encore fait de pronostics. Rendez-vous sur la page 
                        <MudLink Href="/worldbet/matches">Matches</MudLink> pour commencer !
                    </span>
                }
            </MudAlert>
        }
        else
        {
            <MudGrid Spacing="3">
                @foreach (var prono in filteredPronostics)
                {
                    var match = matchesDict.GetValueOrDefault(prono.MatchId);
                    if (match == null) continue;

                    <MudItem xs="12" sm="6" md="4">
                        <MatchCard Match="@match" 
                                   HasPronostic="true" 
                                   UserPronostic="@prono"
                                   OnPronosticSaved="@HandlePronosticUpdated" />
                    </MudItem>
                }
            </MudGrid>
        }
    }
</MudContainer>

@code {
    private List<PronosticDto> pronostics = new();
    private List<PronosticDto> filteredPronostics = new();
    private Dictionary<int, MatchDto> matchesDict = new();
    private List<string> uniquePhases = new();

    private bool isLoading = true;

    // Filters
    private string filterStatus = "";
    private string filterPhase = "";
    private bool showOnlyWithPoints = false;

    // Stats
    private int totalPoints = 0;
    private int exactScores = 0;
    private int pendingCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Refilter when filter parameters change
        FilterPronostics();
    }

    private async Task LoadData()
    {
        isLoading = true;

        try
        {
            var pronosticsTask = PronosticService.GetMyPronosticsAsync();
            var matchesTask = TournamentService.GetAllMatchesAsync();

            await Task.WhenAll(pronosticsTask, matchesTask);

            pronostics = await pronosticsTask;
            var matches = await matchesTask;

            matchesDict = matches.ToDictionary(m => m.MatchId);

            // Extract unique phases from matches that have pronostics
            uniquePhases = pronostics
                .Select(p => matchesDict.GetValueOrDefault(p.MatchId)?.PhaseName)
                .Where(p => p != null)
                .Distinct()
                .OrderBy(p => p)
                .ToList()!;

            // Calculate stats
            CalculateStats();

            FilterPronostics();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lors du chargement : {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void CalculateStats()
    {
        totalPoints = pronostics.Sum(p => p.PointsEarned);
        
        exactScores = pronostics.Count(p => 
        {
            var match = matchesDict.GetValueOrDefault(p.MatchId);
            return match != null && IsExactScore(p, match);
        });
        
        pendingCount = pronostics.Count(p => 
        {
            var match = matchesDict.GetValueOrDefault(p.MatchId);
            return match != null && match.Status != MatchStatus.Finished;
        });
    }

    private void FilterPronostics()
    {
        filteredPronostics = pronostics.Where(p =>
        {
            var match = matchesDict.GetValueOrDefault(p.MatchId);
            if (match == null) return false;

            // Filter by status
            if (!string.IsNullOrEmpty(filterStatus))
            {
                if (filterStatus == "pending" && match.Status == MatchStatus.Finished)
                    return false;
                if (filterStatus == "correct" && (match.Status != MatchStatus.Finished || p.PointsEarned == 0))
                    return false;
                if (filterStatus == "incorrect" && (match.Status != MatchStatus.Finished || p.PointsEarned > 0))
                    return false;
            }

            // Filter by phase
            if (!string.IsNullOrEmpty(filterPhase) && match.PhaseName != filterPhase)
                return false;

            // Filter by points
            if (showOnlyWithPoints && p.PointsEarned == 0)
                return false;

            return true;
        })
        .OrderByDescending(p => 
        {
            var match = matchesDict.GetValueOrDefault(p.MatchId);
            return match?.ScheduledDate ?? DateTime.MinValue;
        })
        .ToList();

        StateHasChanged();
    }

    private async Task HandlePronosticUpdated(PronosticDto updatedProno)
    {
        // Update the pronostic in the list
        var index = pronostics.FindIndex(p => p.PronosticId == updatedProno.PronosticId);
        if (index >= 0)
        {
            pronostics[index] = updatedProno;
        }
        else
        {
            pronostics.Add(updatedProno);
        }

        // Recalculate stats
        CalculateStats();
        
        // Refilter
        FilterPronostics();

        Snackbar.Add($"Pronostic mis à jour : {updatedProno.PredictedScoreTeam1}-{updatedProno.PredictedScoreTeam2}", Severity.Success);
    }

    private bool IsExactScore(PronosticDto prono, MatchDto match)
    {
        return match.ScoreTeam1.HasValue 
            && match.ScoreTeam2.HasValue
            && prono.PredictedScoreTeam1 == match.ScoreTeam1 
            && prono.PredictedScoreTeam2 == match.ScoreTeam2;
    }
}