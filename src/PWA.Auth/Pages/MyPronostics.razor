@page "/worldbet/my-pronostics"
@using PWA.Auth.Pages.WorldBet.Shared
@using dto.worldbet.Models
@using dto.worldbet.Enums
@using dto.worldbet.Requests
@layout WorldBetLayout
@inject IPronosticService PronosticService
@inject ITournamentService TournamentService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService
@attribute [Authorize]

<PageTitle>Mes Pronostics</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Bolt" Class="me-2" />
        Mes Pronostics
    </MudText>

    @if (isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }
    else
    {
        <!-- Statistics Cards -->
        <MudGrid Class="mb-4">
            <MudItem xs="6" sm="3">
                <MudPaper Elevation="2" Class="pa-3 pa-sm-4">
                    <div class="stat-card">
                        <MudAvatar Color="Color.Primary" Size="Size.Medium" Class="stat-avatar">
                            <MudIcon Icon="@Icons.Material.Filled.Bolt" />
                        </MudAvatar>
                        <div class="stat-text">
                            <MudText Typo="Typo.h5">@pronostics.Count</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Pronostics</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudPaper Elevation="2" Class="pa-3 pa-sm-4">
                    <div class="stat-card">
                        <MudAvatar Color="Color.Success" Size="Size.Medium" Class="stat-avatar">
                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" />
                        </MudAvatar>
                        <div class="stat-text">
                            <MudText Typo="Typo.h5">@totalPoints</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Points</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudPaper Elevation="2" Class="pa-3 pa-sm-4">
                    <div class="stat-card">
                        <MudAvatar Color="Color.Info" Size="Size.Medium" Class="stat-avatar">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
                        </MudAvatar>
                        <div class="stat-text">
                            <MudText Typo="Typo.h5">@exactScores</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Scores exacts</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudPaper Elevation="2" Class="pa-3 pa-sm-4">
                    <div class="stat-card">
                        <MudAvatar Color="Color.Warning" Size="Size.Medium" Class="stat-avatar">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" />
                        </MudAvatar>
                        <div class="stat-text">
                            <MudText Typo="Typo.h5">@pendingCount</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">En attente</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Filters -->
        <MudPaper Class="pa-4 mb-4" Elevation="2">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4">
                    <MudSelect T="string"
                               @bind-Value="filterStatus"
                               Label="Statut"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               AdornmentIcon="@Icons.Material.Filled.FilterList">
                        <MudSelectItem Value="@("")">Tous les statuts</MudSelectItem>
                        <MudSelectItem Value="@("pending")">En attente</MudSelectItem>
                        <MudSelectItem Value="@("correct")">Gagnés</MudSelectItem>
                        <MudSelectItem Value="@("incorrect")">Perdus</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string"
                               @bind-Value="filterPhase"
                               Label="Phase"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               AdornmentIcon="@Icons.Material.Filled.Stadium">
                        <MudSelectItem Value="@("")">Toutes les phases</MudSelectItem>
                        @foreach (var phase in uniquePhases)
                        {
                            <MudSelectItem Value="@phase">@phase</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4" Class="d-flex align-items-center">
                    <MudSwitch @bind-Value="showOnlyWithPoints"
                               Color="Color.Primary"
                               Label="Seulement avec points" />
                </MudItem>
            </MudGrid>
        </MudPaper>

        <!-- Pronostics Grid -->
        @if (!filteredPronostics.Any())
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">
                @if (filterStatus != "" || filterPhase != "" || showOnlyWithPoints)
                {
                    <span>Aucun pronostic ne correspond à ces critères.</span>
                }
                else
                {
                    <span>Vous n'avez pas encore fait de pronostics. Rendez-vous sur la page
                        <MudLink Href="/worldbet/matches">Matchs</MudLink> pour commencer !
                    </span>
                }
            </MudAlert>
        }
        else
        {
            <MudGrid Spacing="3">
                @foreach (var prono in filteredPronostics)
                {
                    if (prono.Match == null) continue;
                    <MudItem xs="12" sm="6" md="4">
                        <MatchCard Match="@prono.Match"
                                   HasPronostic="true"
                                   UserPronostic="@prono"
                                   OnPronosticSaved="@HandlePronosticUpdated"
                                   IsAdmin="@isAdmin"
                                   OnEdit="@EditMatch"
                                   OnDelete="@ConfirmDelete"
                                   OnCalculated="@LoadData" />
                    </MudItem>
                }
            </MudGrid>
        }
    }
</MudContainer>

<!-- Match Form Modal (Admin only) -->
<MatchFormModal @bind-IsVisible="showModal"
                Model="@currentRequest"
                Teams="@allTeams"
                Phases="@allPhases"
                IsLoading="@isSaving"
                ErrorMessage="@modalError"
                IsEditMode="true"
                OnSubmit="SaveMatch"
                OnCancel="CloseModal" />

@code {
    private List<PronosticDto> pronostics = new();
    private List<PronosticDto> filteredPronostics = new();
    private List<string> uniquePhases = new();
    private bool isLoading = true;
    private bool isAdmin = false;

    // Admin
    private List<TeamDto> allTeams = new();
    private List<PhaseDto> allPhases = new();
    private bool showModal = false;
    private bool isSaving = false;
    private string? modalError;
    private CreateMatchRequest currentRequest = new();
    private int currentMatchId = 0;

    // Filters
    private string _filterStatus = "";
    private string filterStatus
    {
        get => _filterStatus;
        set { _filterStatus = value; FilterPronostics(); }
    }

    private string _filterPhase = "";
    private string filterPhase
    {
        get => _filterPhase;
        set { _filterPhase = value; FilterPronostics(); }
    }

    private bool _showOnlyWithPoints = false;
    private bool showOnlyWithPoints
    {
        get => _showOnlyWithPoints;
        set { _showOnlyWithPoints = value; FilterPronostics(); }
    }

    // Stats
    private int totalPoints = 0;
    private int exactScores = 0;
    private int pendingCount = 0;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAdmin = authState.User.IsInRole("Admin");

        if (isAdmin)
        {
            var teamsTask = TournamentService.GetAllTeamsAsync();
            var phasesTask = TournamentService.GetAllPhasesAsync();
            await Task.WhenAll(teamsTask, phasesTask);
            allTeams = await teamsTask;
            allPhases = await phasesTask;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            pronostics = await PronosticService.GetMyPronosticsAsync();

            uniquePhases = pronostics
                .Select(p => p.Match?.PhaseName)
                .Where(p => p != null)
                .Distinct()
                .OrderBy(p => p)
                .ToList()!;

            CalculateStats();
            FilterPronostics();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lors du chargement : {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void CalculateStats()
    {
        totalPoints  = pronostics.Sum(p => p.PointsEarned);
        exactScores  = pronostics.Count(p => p.IsCorrectScore);
        pendingCount = pronostics.Count(p => p.Match?.Status != MatchStatus.Finished);
    }

    private void FilterPronostics()
    {
        filteredPronostics = pronostics.Where(p =>
        {
            if (p.Match == null) return false;

            if (!string.IsNullOrEmpty(filterStatus))
            {
                if (filterStatus == "pending"   && p.Match.Status == MatchStatus.Finished)  return false;
                if (filterStatus == "correct"   && (p.Match.Status != MatchStatus.Finished || p.PointsEarned == 0)) return false;
                if (filterStatus == "incorrect" && (p.Match.Status != MatchStatus.Finished || p.PointsEarned > 0))  return false;
            }

            if (!string.IsNullOrEmpty(filterPhase) && p.Match.PhaseName != filterPhase) return false;
            if (showOnlyWithPoints && p.PointsEarned == 0) return false;

            return true;
        })
        .OrderByDescending(p => p.Match?.ScheduledDate ?? DateTime.MinValue)
        .ToList();

        StateHasChanged();
    }

    private async Task HandlePronosticUpdated(PronosticDto updatedProno)
    {
        var index = pronostics.FindIndex(p => p.PronosticId == updatedProno.PronosticId);
        if (index >= 0)
            pronostics[index] = updatedProno;
        else
            pronostics.Add(updatedProno);

        CalculateStats();
        FilterPronostics();

        Snackbar.Add($"Pronostic mis à jour : {updatedProno.PredictedScoreTeam1}-{updatedProno.PredictedScoreTeam2}", Severity.Success);
    }

    private void EditMatch(MatchDto match)
    {
        currentMatchId = match.MatchId;
        currentRequest = new CreateMatchRequest
        {
            PhaseId           = match.PhaseId,
            Team1Id           = match.Team1Id,
            Team2Id           = match.Team2Id,
            ScheduledDate     = match.ScheduledDate,
            Venue             = match.Venue,
            MatchNumber       = match.MatchNumber,
            GroupLetter       = match.GroupLetter,
            ScoreTeam1        = match.ScoreTeam1,
            ScoreTeam2        = match.ScoreTeam2,
            Status            = match.Status,
            LockPronosticsAt  = match.LockPronosticsAt,
            FinishedType      = match.FinishedType,
            PenaltyWinnerTeam = match.PenaltyWinnerTeam
        };
        modalError = null;
        showModal = true;
    }

    private async Task SaveMatch()
    {
        isSaving = true;
        modalError = null;
        try
        {
            var updateRequest = new UpdateMatchRequest
            {
                PhaseId           = currentRequest.PhaseId,
                Team1Id           = currentRequest.Team1Id,
                Team2Id           = currentRequest.Team2Id,
                ScheduledDate     = currentRequest.ScheduledDate,
                Venue             = currentRequest.Venue,
                MatchNumber       = currentRequest.MatchNumber,
                GroupLetter       = currentRequest.GroupLetter,
                ScoreTeam1        = currentRequest.ScoreTeam1,
                ScoreTeam2        = currentRequest.ScoreTeam2,
                Status            = currentRequest.Status,
                LockPronosticsAt  = currentRequest.LockPronosticsAt,
                FinishedType      = currentRequest.FinishedType,
                PenaltyWinnerTeam = currentRequest.PenaltyWinnerTeam
            };
            await TournamentService.UpdateMatchAsync(currentMatchId, updateRequest);
            Snackbar.Add("Match modifié avec succès !", Severity.Success);
            await LoadData();
            CloseModal();
        }
        catch (Exception ex)
        {
            modalError = $"Erreur : {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ConfirmDelete(MatchDto match)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Confirmer la suppression",
            $"Supprimer {match.Team1Name} vs {match.Team2Name} ?\n\n⚠️ Cette action est irréversible.",
            yesText: "Supprimer",
            cancelText: "Annuler");

        if (result == true)
        {
            try
            {
                await TournamentService.DeleteMatchAsync(match.MatchId);
                Snackbar.Add("Match supprimé.", Severity.Success);
                await LoadData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
            }
        }
    }

    private void CloseModal()
    {
        showModal = false;
        currentRequest = new();
        currentMatchId = 0;
        modalError = null;
    }
}

<style>
    .stat-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 0.5rem;
    }

    @@media (min-width: 600px) {
        .stat-card {
            flex-direction: row;
            text-align: left;
        }

        .stat-avatar {
            margin-right: 0.75rem;
            flex-shrink: 0;
        }
    }
</style>