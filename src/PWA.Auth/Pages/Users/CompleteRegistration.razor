@* Pages/Users/CompleteRegistration.razor *@
@page "/complete-registration"
@using dto.user.Models
@attribute [AllowAnonymous]
@inject IUserService UserService
@inject NavigationManager Navigation

<PageTitle>Finaliser l'inscription - MaesAuth</PageTitle>

<div class="registration-page">
    <MudPaper Elevation="3" Class="registration-card pa-6">

        @if (!isTokenValid)
        {
            <div class="text-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.LinkOff"
                         Color="Color.Error"
                         Style="font-size: 4rem;" />
            </div>
            <MudAlert Severity="Severity.Error" Class="mb-4">
                <strong>Lien invalide ou expiré</strong>
                <br />Ce lien d'invitation est invalide ou a expiré. Veuillez contacter l'administrateur.
            </MudAlert>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Login"
                       OnClick="@(() => Navigation.NavigateTo("/login"))">
                Retour à la connexion
            </MudButton>
        }
        else if (isSuccess)
        {
            <div class="text-center">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                         Color="Color.Success"
                         Style="font-size: 4rem;" />
                <MudText Typo="Typo.h5" Class="mt-3 mb-2">Inscription finalisée !</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    Votre compte est activé. Vous pouvez maintenant vous connecter.
                </MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Login"
                           OnClick="@(() => Navigation.NavigateTo("/login"))">
                    Se connecter
                </MudButton>
            </div>
        }
        else
        {
            <PasswordSetupForm
                Title="Finaliser votre inscription"
                Description="Choisissez un mot de passe pour activer votre compte"
                IconClass="bi bi-person-check"
                SubmitButtonText="Activer mon compte"
                LoadingText="Activation..."
                IsLoading="@isLoading"
                IsSuccess="@isSuccess"
                ErrorMessage="@errorMessage"
                OnSubmit="HandlePasswordSubmit" />
        }

    </MudPaper>
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private bool isLoading = false;
    private bool isSuccess = false;
    private bool isTokenValid = true;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(Token))
        {
            isTokenValid = false;
            errorMessage = "Aucun token d'invitation fourni";
        }
    }

    private async Task HandlePasswordSubmit(PasswordSetupForm.PasswordSetupModel model)
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var request = new CompleteUserRegistrationRequest
            {
                Token = Token!,
                Password = model.Password,
                ConfirmPassword = model.ConfirmPassword
            };

            var response = await UserService.CompleteUserRegistration(request);


            if (response.Success)
                isSuccess = true;
            else
                errorMessage = response.ErrorMessage ?? "Échec de l'activation du compte";
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}

<style>
    .registration-page {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 1rem;
    }

    .registration-card {
        width: 100%;
        max-width: 440px;
        border-radius: 12px;
        animation: slideUp 0.4s ease-out;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>