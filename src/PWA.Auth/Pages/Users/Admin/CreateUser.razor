@* Pages/Admin/CreateUser.razor *@
@page "/admin/users/new"
@attribute [Authorize(Roles = "Admin")]
@using dto.user.Models
@using dto.common.Enums
@using PWA.Auth.Models
@inject IUserService UserService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Créer un utilisateur - MaesAuth</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-4">

    <!-- Header -->
    <div class="d-flex align-items-center mb-4 gap-3">
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="GoBack">
            Retour
        </MudButton>
        <MudText Typo="Typo.h4">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="me-2" />
            Créer un utilisateur
        </MudText>
    </div>

    <MudPaper Elevation="2" Class="pa-5">

        <MudAlert Severity="Severity.Info" Class="mb-4">
            <strong>Processus d'invitation :</strong>
            <ul class="mb-0 mt-2">
                <li>L'utilisateur recevra un email d'invitation</li>
                <li>Il devra cliquer sur le lien pour définir son mot de passe</li>
                <li>Son compte sera activé une fois l'inscription complétée</li>
            </ul>
        </MudAlert>

        <UserForm Mode="FormMode.Create"
                  OnSubmit="HandleCreateUser"
                  OnCancel="GoBack"
                  IsLoading="@isLoading"
                  ErrorMessage="@errorMessage"
                  ShowAdminOptions="true"
                  RequirePassword="false" />

    </MudPaper>

</MudContainer>

@code {
    private bool isLoading = false;
    private string? errorMessage;

    private async Task HandleCreateUser(UserFormModel formData)
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var request = new CreateUserInvitationRequest
            {
                Email     = formData.Email,
                FirstName = formData.FirstName,
                LastName  = formData.LastName,
                IsAdmin   = formData.IsAdmin
            };

            var response = await UserService.CreateUserInvitation(request);

            if (response.Success)
            {
                Snackbar.Add($"Invitation envoyée à {formData.Email}", Severity.Success);
                await Task.Delay(1500);
                Navigation.NavigateTo("/admin/users");
            }
            else
            {
                errorMessage = response.ErrorMessage ?? "Impossible d'envoyer l'invitation";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/admin/users");
}