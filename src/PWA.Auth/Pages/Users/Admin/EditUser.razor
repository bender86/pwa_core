@* Pages/Admin/EditUser.razor *@
@page "/admin/users/edit/{UserId:int}"
@using dto.user.Models
@using dto.common.Enums
@using PWA.Auth.Components.UserForm
@using PWA.Auth.Components.UserApplications
@using PWA.Auth.Models
@inject IUserService UserService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject ILogger<EditUser> Logger

<PageTitle>Modifier l'utilisateur - MaesAuth</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <MudText Typo="Typo.h4" Class="mb-1">
                <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Class="me-2" />
                Modifier l'utilisateur
            </MudText>
            <MudBreadcrumbs Items="@breadcrumbs" />
        </div>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="NavigateBack">
            Retour
        </MudButton>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Class="mt-3" Color="Color.Secondary">Chargement de l'utilisateur...</MudText>
        </div>
    }
    else if (userData == null)
    {
        <MudAlert Severity="Severity.Error">
            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Class="me-2" />
            Utilisateur introuvable.
        </MudAlert>
    }
    else
    {
        <MudGrid Spacing="4">

            <!-- Informations utilisateur -->
            <MudItem xs="12" lg="6">
                <MudPaper Elevation="2" Style="overflow: hidden;">
                    <div style="background: var(--mud-palette-primary); padding: 0.75rem 1rem;">
                        <MudText Typo="Typo.body1" Style="color: white; font-weight: 500;">
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Class="me-2" Size="Size.Small" />
                            Informations
                        </MudText>
                    </div>
                    <div class="pa-4">
                        <UserForm Mode="FormMode.Edit"
                                  InitialData="userData"
                                  OnSubmit="HandleUpdateUser"
                                  IsLoading="@isSaving"
                                  ErrorMessage="@errorMessage"
                                  ShowAdminOptions="true"
                                  ShowCancelButton="false" />
                    </div>
                </MudPaper>
            </MudItem>

            <!-- Applications -->
            <MudItem xs="12" lg="6">
                <UserApplications UserId="@UserId"
                                  OnApplicationsChanged="HandleApplicationsChanged" />
            </MudItem>

            <!-- Métadonnées -->
            <MudItem xs="12">
                <MudPaper Elevation="2" Style="overflow: hidden;">
                    <div style="background: var(--mud-palette-background-grey); padding: 0.75rem 1rem; border-bottom: 1px solid var(--mud-palette-divider);">
                        <MudText Typo="Typo.body1" Style="font-weight: 500;">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Class="me-2" Size="Size.Small" />
                            Métadonnées
                        </MudText>
                    </div>
                    <div class="pa-4">
                        <MudGrid Spacing="3">
                            <MudItem xs="12" sm="6" md="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">ID</MudText>
                                <MudText Typo="Typo.body1" Style="font-weight: 500;">@userDetail?.Id</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText>
                                <MudText Typo="Typo.body1" Style="font-weight: 500;">@userDetail?.Email</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Créé le</MudText>
                                <MudText Typo="Typo.body1">@userDetail?.CreatedAt.ToString("dd/MM/yyyy HH:mm")</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">MFA</MudText>
                                <MudChip T="string"
                                         Size="Size.Small"
                                         Color="@(userDetail?.MfaEnabled == true ? Color.Success : Color.Default)"
                                         Icon="@(userDetail?.MfaEnabled == true ? Icons.Material.Filled.Shield : Icons.Material.Filled.ShieldMoon)">
                                    @(userDetail?.MfaEnabled == true ? "Activé" : "Désactivé")
                                </MudChip>
                            </MudItem>
                        </MudGrid>
                    </div>
                </MudPaper>
            </MudItem>

        </MudGrid>
    }

</MudContainer>

@code {
    [Parameter] public int UserId { get; set; }

    private UserFormModel? userData;
    private UserDetailResponse? userDetail;
    private bool isLoading = false;
    private bool isSaving = false;
    private string? errorMessage;

    private List<BreadcrumbItem> breadcrumbs = new()
    {
        new BreadcrumbItem("Admin",  href: "/admin"),
        new BreadcrumbItem("Utilisateurs", href: "/admin/users"),
        new BreadcrumbItem("Modifier", href: null, disabled: true)
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadUser();
    }

    private async Task LoadUser()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var result = await UserService.GetUserById(UserId);
            if (result.Success && result.Data != null)
            {
                userDetail = result.Data;
                userData = new UserFormModel
                {
                    Id          = result.Data.Id,
                    FirstName   = result.Data.FirstName,
                    LastName    = result.Data.LastName,
                    Email       = result.Data.Email,
                    IsAdmin     = result.Data.IsAdmin ?? false,
                    Active      = result.Data.Active ?? false,
                    MfaEnabled  = result.Data.MfaEnabled ?? false,
                    CreatedDate = result.Data.CreatedAt
                };
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Impossible de charger l'utilisateur";
                Logger.LogError("Failed to load user {UserId}: {Error}", UserId, result.ErrorMessage);
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur lors du chargement";
            Logger.LogError(ex, "Error loading user {UserId}", UserId);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleUpdateUser(UserFormModel model)
    {
        isSaving = true;
        errorMessage = null;
        try
        {
            var result = await UserService.UpdateUser(new UpdateUserRequest
            {
                Id        = model.Id,
                FirstName = model.FirstName,
                LastName  = model.LastName,
                IsAdmin   = model.IsAdmin,
                Active    = model.Active
            });

            if (result.Success)
            {
                Snackbar.Add("Utilisateur mis à jour avec succès", Severity.Success);
                Navigation.NavigateTo("/admin/users");
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Impossible de mettre à jour l'utilisateur";
                Logger.LogError("Failed to update user {UserId}: {Error}", UserId, result.ErrorMessage);
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur lors de la mise à jour";
            Logger.LogError(ex, "Error updating user {UserId}", UserId);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task HandleApplicationsChanged() => await LoadUser();

    private void NavigateBack() => Navigation.NavigateTo("/admin/users");
}