@* Pages/Admin/ManageUsers.razor *@
@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@using dto.user.Models
@using dto.user.Enums
@inject IUserService UserService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Gestion des utilisateurs - MaesAuth</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div class="d-flex align-items-center gap-3">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => Navigation.NavigateTo("/admin"))">
                Retour
            </MudButton>
            <MudText Typo="Typo.h4">
                <MudIcon Icon="@Icons.Material.Filled.People" Class="me-2" />
                Utilisateurs
            </MudText>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="@(() => Navigation.NavigateTo("/admin/users/new"))">
            Nouvel utilisateur
        </MudButton>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" ShowCloseIcon="true"
                  CloseIconClicked="() => errorMessage = null"
                  Class="mb-4">
            @errorMessage
        </MudAlert>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Class="mt-3" Color="Color.Secondary">Chargement des utilisateurs...</MudText>
        </div>
    }
    else if (users == null || !users.Any())
    {
        <div class="text-center py-5">
            <MudIcon Icon="@Icons.Material.Filled.PeopleOutline"
                     Color="Color.Secondary"
                     Style="font-size: 4rem;" />
            <MudText Typo="Typo.h5" Class="mt-3">Aucun utilisateur</MudText>
            <MudText Color="Color.Secondary">Créez votre premier utilisateur pour commencer</MudText>
        </div>
    }
    else
    {
        <MudPaper Elevation="2">
            <MudDataGrid T="UserDetailResponse"
                         Items="@users"
                         Dense="true"
                         Hover="true"
                         Bordered="false"
                         Striped="true"
                         Filterable="false"
                         SortMode="SortMode.Single">
                <Columns>

                    <PropertyColumn Property="x => x.Id" Title="ID" Sortable="true" />

                    <PropertyColumn Property="x => x.Email" Title="Email" Sortable="true" />

                    <TemplateColumn Title="Nom" Sortable="false">
                        <CellTemplate>
                            <MudText Typo="Typo.body2">
                                @context.Item.FirstName @context.Item.LastName
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>

                    <TemplateColumn Title="Rôle" Sortable="false">
                        <CellTemplate>
                            @if (context.Item.IsAdmin == true)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Admin</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">Utilisateur</MudChip>
                            }
                        </CellTemplate>
                    </TemplateColumn>

                    <TemplateColumn Title="Statut" Sortable="false">
                        <CellTemplate>
                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Item.Status)">
                                @GetStatusLabel(context.Item.Status)
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>

                    <TemplateColumn Title="MFA" Sortable="false">
                        <CellTemplate>
                            <MudIcon Icon="@(context.Item.MfaEnabled == true ? Icons.Material.Filled.Shield : Icons.Material.Filled.ShieldMoon)"
                                     Color="@(context.Item.MfaEnabled == true ? Color.Success : Color.Default)"
                                     Size="Size.Small" />
                        </CellTemplate>
                    </TemplateColumn>

                    <PropertyColumn Property="x => x.CreatedAt" Title="Créé le" Sortable="true">
                        <CellTemplate>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @context.Item.CreatedAt.ToString("dd/MM/yyyy")
                            </MudText>
                        </CellTemplate>
                    </PropertyColumn>

                    <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
                        <CellTemplate>
                            <div class="d-flex gap-1">
                                @if (context.Item.Status == UserStatus.Pending)
                                {
                                    <MudTooltip Text="Approuver">
                                        <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                                       Color="Color.Success"
                                                       Size="Size.Small"
                                                       OnClick="@(() => ApproveUser(context.Item.Id))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Rejeter">
                                        <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                                       Color="Color.Error"
                                                       Size="Size.Small"
                                                       OnClick="@(() => RejectUser(context.Item.Id))" />
                                    </MudTooltip>
                                }
                                <MudTooltip Text="Modifier">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   OnClick="@(() => Navigation.NavigateTo($"/admin/users/edit/{context.Item.Id}"))" />
                                </MudTooltip>
                                @if (context.Item.Status != UserStatus.Suspended)
                                {
                                    <MudTooltip Text="Suspendre">
                                        <MudIconButton Icon="@Icons.Material.Filled.PauseCircle"
                                                       Color="Color.Warning"
                                                       Size="Size.Small"
                                                       OnClick="@(() => SuspendUser(context.Item.Id))" />
                                    </MudTooltip>
                                }
                                else
                                {
                                    <MudTooltip Text="Réactiver">
                                        <MudIconButton Icon="@Icons.Material.Filled.PlayCircle"
                                                       Color="Color.Success"
                                                       Size="Size.Small"
                                                       OnClick="@(() => ReactivateUser(context.Item.Id))" />
                                    </MudTooltip>
                                }
                                <MudTooltip Text="Supprimer">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="@(() => DeleteUser(context.Item.Id))" />
                                </MudTooltip>
                            </div>
                        </CellTemplate>
                    </TemplateColumn>

                </Columns>

                <PagerContent>
                    <MudDataGridPager T="UserDetailResponse" />
                </PagerContent>

                <NoRecordsContent>
                    <MudText Class="pa-4" Color="Color.Secondary">Aucun utilisateur trouvé.</MudText>
                </NoRecordsContent>

            </MudDataGrid>

            <div class="pa-3" style="border-top: 1px solid var(--mud-palette-divider);">
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Total : @users.Count utilisateur(s)
                </MudText>
            </div>
        </MudPaper>
    }

</MudContainer>

@code {
    private List<UserDetailResponse>? users;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync() => await LoadUsers();

    private async Task LoadUsers()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var response = await UserService.GetAllUsers();
            if (response.Success && response.Data != null)
                users = response.Data.ToList();
            else
                errorMessage = response.ErrorMessage ?? "Impossible de charger les utilisateurs";
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApproveUser(int userId)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Confirmer", "Approuver cet utilisateur et activer son compte ?",
            yesText: "Approuver", cancelText: "Annuler");
        if (result == true) await ChangeUserStatus(userId, UserStatus.Active);
    }

    private async Task RejectUser(int userId)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Confirmer", "Rejeter la demande d'inscription de cet utilisateur ?",
            yesText: "Rejeter", cancelText: "Annuler");
        if (result == true) await ChangeUserStatus(userId, UserStatus.Rejected);
    }

    private async Task SuspendUser(int userId)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Confirmer", "Suspendre le compte de cet utilisateur ?",
            yesText: "Suspendre", cancelText: "Annuler");
        if (result == true) await ChangeUserStatus(userId, UserStatus.Suspended);
    }

    private async Task ReactivateUser(int userId)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Confirmer", "Réactiver le compte de cet utilisateur ?",
            yesText: "Réactiver", cancelText: "Annuler");
        if (result == true) await ChangeUserStatus(userId, UserStatus.Active);
    }

    private async Task ChangeUserStatus(int userId, UserStatus newStatus)
    {
        try
        {
            var response = await UserService.UpdateUserStatus(userId, newStatus);
            if (response.Success)
            {
                Snackbar.Add("Statut mis à jour avec succès", Severity.Success);
                await LoadUsers();
            }
            else
            {
                errorMessage = response.ErrorMessage ?? "Impossible de mettre à jour le statut";
            }
        }
        catch (Exception ex) { errorMessage = $"Erreur : {ex.Message}"; }
    }

    private async Task DeleteUser(int userId)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Confirmer la suppression",
            "Supprimer définitivement cet utilisateur ? Cette action est irréversible.",
            yesText: "Supprimer", cancelText: "Annuler");

        if (result == true)
        {
            try
            {
                var response = await UserService.DeleteUser(userId);
                if (response.Success)
                {
                    Snackbar.Add("Utilisateur supprimé", Severity.Success);
                    await LoadUsers();
                }
                else
                {
                    errorMessage = response.ErrorMessage ?? "Impossible de supprimer l'utilisateur";
                }
            }
            catch (Exception ex) { errorMessage = $"Erreur : {ex.Message}"; }
        }
    }

    private Color GetStatusColor(UserStatus? status) => status switch
    {
        UserStatus.Active    => Color.Success,
        UserStatus.Pending   => Color.Warning,
        UserStatus.Rejected  => Color.Error,
        UserStatus.Suspended => Color.Default,
        UserStatus.Inactive  => Color.Default,
        _                    => Color.Default
    };

    private string GetStatusLabel(UserStatus? status) => status switch
    {
        UserStatus.Active    => "Actif",
        UserStatus.Pending   => "En attente",
        UserStatus.Rejected  => "Rejeté",
        UserStatus.Suspended => "Suspendu",
        UserStatus.Inactive  => "Inactif",
        _                    => "Inconnu"
    };
}