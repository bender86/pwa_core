@page "/change-password"
@attribute [Authorize]
@using dto.user.Models
@inject IUserService UserService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Changer mon mot de passe - MaesAuth</PageTitle>

<div class="change-password-page">
    <MudPaper Elevation="3" Class="change-password-card pa-6">

        <div class="d-flex align-items-center mb-4 gap-3">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           Variant="Variant.Outlined"
                           Size="Size.Small"
                           OnClick="@(() => Navigation.NavigateTo("/profile"))" />
            <div>
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Changer mon mot de passe</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Saisissez votre mot de passe actuel puis le nouveau</MudText>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
        }

        <MudForm @ref="form" @bind-IsValid="isValid">

            <MudTextField T="string"
                          @bind-Value="currentPassword"
                          Label="Mot de passe actuel"
                          InputType="@currentPwdType"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="Le mot de passe actuel est requis"
                          Disabled="@isLoading"
                          Adornment="Adornment.End"
                          AdornmentIcon="@currentPwdIcon"
                          OnAdornmentClick="@(() => showCurrent = !showCurrent)"
                          Class="mb-3" />

            <MudTextField T="string"
                          @bind-Value="newPassword"
                          Label="Nouveau mot de passe"
                          InputType="@newPwdType"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="Le nouveau mot de passe est requis"
                          Validation="@(new Func<string, string?>(ValidateNewPassword))"
                          Disabled="@isLoading"
                          Adornment="Adornment.End"
                          AdornmentIcon="@newPwdIcon"
                          OnAdornmentClick="@(() => showNew = !showNew)"
                          HelperText="Minimum 8 caractères"
                          Class="mb-3" />

            <MudTextField T="string"
                          @bind-Value="confirmPassword"
                          Label="Confirmer le nouveau mot de passe"
                          InputType="@confirmPwdType"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="La confirmation est requise"
                          Validation="@(new Func<string, string?>(ValidateConfirm))"
                          Disabled="@isLoading"
                          Adornment="Adornment.End"
                          AdornmentIcon="@confirmPwdIcon"
                          OnAdornmentClick="@(() => showConfirm = !showConfirm)"
                          Class="mb-4" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="@(!isValid || isLoading)"
                       OnClick="HandleSubmit">
                @if (isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                    <span>Enregistrement...</span>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Class="me-2" />
                    <span>Changer le mot de passe</span>
                }
            </MudButton>

        </MudForm>

    </MudPaper>
</div>

@code {
    private MudForm? form;
    private bool isValid;
    private bool isLoading;
    private string? errorMessage;

    private string currentPassword = "";
    private string newPassword = "";
    private string confirmPassword = "";

    private bool showCurrent = false;
    private bool showNew     = false;
    private bool showConfirm = false;

    private InputType currentPwdType => showCurrent ? InputType.Text : InputType.Password;
    private InputType newPwdType     => showNew     ? InputType.Text : InputType.Password;
    private InputType confirmPwdType => showConfirm ? InputType.Text : InputType.Password;

    private string currentPwdIcon => showCurrent ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    private string newPwdIcon     => showNew     ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    private string confirmPwdIcon => showConfirm ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    private int userId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await UserService.GetCurrentUser();
        userId = user?.Id ?? 0;
    }

    private string? ValidateNewPassword(string value)
    {
        if (string.IsNullOrEmpty(value)) return "Le nouveau mot de passe est requis";
        if (value.Length < 8) return "Minimum 8 caractères";
        if (value == currentPassword) return "Le nouveau mot de passe doit être différent de l'ancien";
        return null;
    }

    private string? ValidateConfirm(string value)
    {
        if (string.IsNullOrEmpty(value)) return "La confirmation est requise";
        if (value != newPassword) return "Les mots de passe ne correspondent pas";
        return null;
    }

    private async Task HandleSubmit()
    {
        if (form != null) await form.Validate();
        if (!isValid) return;

        isLoading = true;
        errorMessage = null;
        try
        {
            var request = new ChangePasswordRequest
            {
                UserId          = userId,
                CurrentPassword = currentPassword,
                NewPassword     = newPassword,
                ConfirmPassword = confirmPassword
            };

            var result = await UserService.ChangePassword(request);

            if (result.Success)
            {
                Snackbar.Add("Mot de passe modifié avec succès !", Severity.Success);
                Navigation.NavigateTo("/profile");
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Erreur lors du changement de mot de passe";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}

<style>
    .change-password-page {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 2rem 1rem;
    }

    .change-password-card {
        width: 100%;
        max-width: 440px;
        border-radius: 12px !important;
        animation: slideUp 0.4s ease-out;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>