@page "/register"
@using PWA.Auth.Components.UserForm
@using PWA.Auth.Models
@using dto.user.Models
@using dto.common.Enums
@attribute [AllowAnonymous]
@inject IUserService UserService
@inject NavigationManager Navigation

<PageTitle>Créer un compte - MaesAuth</PageTitle>

<div class="register-page">
    <MudPaper Elevation="3" Class="register-card pa-6">

        <div class="text-center mb-4">
            <MudText Typo="Typo.h5" Style="font-weight: 600;">🔐 MaesAuth</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Créer votre compte</MudText>
        </div>

        @if (!registrationSuccess)
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">
                <strong>Processus d'inscription :</strong>
                <ul class="mb-0 mt-2">
                    <li>L'admin recevra une demande d'inscription</li>
                    <li>Une fois validé, vous recevrez un email pour vous prévenir que vous pouvez vous connecter</li>
                </ul>
            </MudAlert>

            <UserForm Mode="FormMode.Create"
                      OnSubmit="HandleRegister"
                      IsLoading="@isLoading"
                      ErrorMessage="@errorMessage"
                      ShowAdminOptions="false"
                      ShowCancelButton="true"
                      RequirePassword="true"
                      OnCancel="NavigateToLogin" />
        }
        else
        {
            <div class="text-center">
                <MudIcon Icon="@Icons.Material.Filled.HowToReg"
                         Color="Color.Success"
                         Style="font-size: 4rem;" />
                <MudText Typo="Typo.h6" Class="mt-3 mb-2">Demande envoyée !</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-1">
                    Votre demande de création de compte a été envoyée.
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                    Un administrateur validera votre compte sous peu.
                </MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Login"
                           OnClick="NavigateToLogin">
                    Retour à la connexion
                </MudButton>
            </div>
        }

    </MudPaper>
</div>

@code {
    private bool isLoading;
    private string? errorMessage;
    private bool registrationSuccess;

    private async Task HandleRegister(UserFormModel model)
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var request = new CreateUserRequest
            {
                Email     = model.Email,
                LastName  = model.LastName,
                FirstName = model.FirstName,
                Password  = model.Password!
            };

            var result = await UserService.CreateUser(request);

            if (result.Success)
                registrationSuccess = true;
            else
                errorMessage = result.ErrorMessage;
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateToLogin() => Navigation.NavigateTo("/login");
}

<style>
    .register-page {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 1rem;
    }

    .register-card {
        width: 100%;
        max-width: 480px;
        border-radius: 12px !important;
        animation: slideUp 0.4s ease-out;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>