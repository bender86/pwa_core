@page "/login"
@page "/user/login"
@attribute [AllowAnonymous]
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Connexion - MaesAuth</PageTitle>

<div class="login-page">
    <MudPaper Elevation="3" Class="login-card pa-6">

        <div class="text-center mb-5">
            <MudText Typo="Typo.h5" Style="font-weight: 600;">🔐 MaesAuth</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Système d'authentification centralisé</MudText>
        </div>

        @if (!requiresMfa)
        {
            <LoginForm IsLoading="@isLoading"
                       ErrorMessage="@errorMessage"
                       OnLoginSubmit="HandleLogin" />

            <MudDivider Class="my-4" />

            <div class="text-center">
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                    Pas encore de compte ?
                </MudText>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.PersonAdd"
                           OnClick="NavigateToRegister">
                    Créer un compte
                </MudButton>
            </div>
        }
        else
        {
            <MfaVerification IsLoading="@isLoading"
                             ErrorMessage="@errorMessage"
                             ShowQrCode="@showQrCode"
                             QrCodeBase64="@qrCodeBase64"
                             SecretKey="@secretKey"
                             PromptMessage="Entrez le code de votre application d'authentification"
                             OnMfaCodeSubmit="HandleMfaVerify"
                             OnCancel="HandleCancelMfa" />
        }

    </MudPaper>
</div>

@code {
    private bool isLoading = false;
    private string? errorMessage;

    // MFA state
    private bool requiresMfa = false;
    private string? mfaSessionId;
    private bool showQrCode = false;
    private string? qrCodeBase64;
    private string? secretKey;

    private async Task HandleLogin(AuthenticateRequest request)
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var result = await AuthService.LoginAsync(request.Email, request.Password);

            if (result.Success && result.Data != null)
            {
                if (result.Data.RequiresMfa)
                {
                    requiresMfa  = true;
                    mfaSessionId = result.Data.MfaSessionId;

                    if (!string.IsNullOrEmpty(result.Data.QrCodeBase64))
                    {
                        showQrCode   = true;
                        qrCodeBase64 = result.Data.QrCodeBase64;
                        secretKey    = result.Data.SecretKey;
                    }
                }
                else
                {
                    await CompleteAuthentication();
                }
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Identifiants invalides";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur de connexion : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleMfaVerify(string code)
    {
        if (string.IsNullOrEmpty(mfaSessionId))
        {
            errorMessage = "Session MFA invalide";
            return;
        }

        isLoading = true;
        errorMessage = null;
        try
        {
            var result = await AuthService.VerifyMfaAsync(mfaSessionId, code);

            if (result.Success && result.Data != null)
            {
                if (!string.IsNullOrEmpty(result.Data.Token))
                    await CompleteAuthentication();
                else
                    errorMessage = "Erreur lors de la génération du token";
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Code MFA invalide";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur de vérification : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleCancelMfa()
    {
        requiresMfa  = false;
        mfaSessionId = null;
        showQrCode   = false;
        qrCodeBase64 = null;
        secretKey    = null;
        errorMessage = null;
    }

    private async Task CompleteAuthentication()
    {
        ((CustomAuthStateProvider)AuthStateProvider).NotifyUserAuthentication();

        var apps = await AuthService.GetUserApplicationDetailsAsync();
        if (apps.Count == 1)
            Navigation.NavigateTo(GetAppRoute(apps[0].AppUrl));
        else
            Navigation.NavigateTo("/");
    }

    private static string GetAppRoute(string? appUrl) =>
    string.IsNullOrEmpty(appUrl) ? "/" : appUrl;

    private void NavigateToRegister() => Navigation.NavigateTo("/register");
}

<style>
    .login-page {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 1rem;
    }

    .login-card {
        width: 100%;
        max-width: 420px;
        border-radius: 12px !important;
        animation: slideUp 0.4s ease-out;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>