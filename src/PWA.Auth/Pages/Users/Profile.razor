@page "/profile"
@page "/user/profile"  
@attribute [Authorize]
@using dto.user.Models
@using PWA.Auth.Models
@using dto.common.Enums
@inject IJSRuntime JS
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject WorldBetApiClient WorldBetApi

@inject IUserService UserService
@inject IMfaService MfaService
@inject NavigationManager Navigation

<PageTitle>Mon profil - MaesAuth</PageTitle>

<div class="profile-page">
    <div class="profile-container">
        <div class="profile-header">
            <h2>👤 Mon Profil</h2>
            <p class="subtitle">Gérer vos informations personnelles</p>
        </div>

        @if (isLoading)
        {
            <div class="loading-spinner">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Chargement...</span>
                </div>
            </div>
        }
        else if (model != null)
        {
            <div class="profile-content">
                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="alert alert-success">
                        ✅ @successMessage
                    </div>
                }

                <!-- ✅ UserForm pour les champs classiques (SANS MFA dedans) -->
                <UserForm Mode="FormMode.Edit"
                          InitialData="@model"
                          OnSubmit="HandleUpdateProfile"
                          OnCancel="LoadProfile"
                          IsLoading="@isSaving"
                          ErrorMessage="@errorMessage"
                          ShowAdminOptions="false"
                          ShowCancelButton="true" />
                <!-- ✅ Section enable notif avec son propre toggle -->
                <div class="mfa-section">
                    <h4>🔔 Notifications WorldBet</h4>

                    @if (!_notifSupported)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">
                            Non disponible dans ce navigateur.<br />
                            Sur iPhone : <strong>Safari → Partager → Sur l'écran d'accueil</strong>
                        </MudAlert>
                    }
                    else if (_notifPermission == "denied")
                    {
                        <MudAlert Severity="Severity.Error" Dense="true">
                            Permission refusée — réactivez les notifications dans les réglages du navigateur.
                        </MudAlert>
                    }
                    else
                    {
                        <MudSwitch T="bool"
                                Value="_notifSubscribed"
                                ValueChanged="HandleNotifToggle"
                                Color="Color.Primary"
                                Disabled="_notifLoading"
                                Label="@(_notifSubscribed ? "Activées" : "Désactivées")" />

                        <small class="mfa-status">
                            @if (_notifSubscribed)
                            {
                                <span class="status-active">✓ Rappel automatique 1h avant chaque match non pronostiqué</span>
                            }
                            else
                            {
                                <span class="status-inactive">Active les rappels pour ne plus rater un pronostic</span>
                            }
                        </small>

                        @if (_notifSubscribed)
                        {
                            <div class="mt-2">
                                <button type="button"
                                        class="btn btn-outline-secondary btn-sm"
                                        @onclick="SendTestNotifAsync"
                                        disabled="@_notifLoading">
                                    @if (_notifLoading)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    📨 Envoyer une notif de test
                                </button>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(_notifMessage))
                        {
                            <small class="d-block mt-2 @(_notifError ? "status-inactive" : "status-active")">
                                @_notifMessage
                            </small>
                        }
                    }
                </div>
                <!-- ✅ Section MFA séparée avec son propre toggle -->
                <div class="mfa-section">
                    <h4>🔐 Sécurité</h4>
                    <div class="form-check">
                        <input type="checkbox" 
                               class="form-check-input" 
                               id="mfaToggle"
                               checked="@currentMfaEnabled"
                               @onchange="HandleMfaToggle"
                               disabled="@isSaving" />
                        <label class="form-check-label" for="mfaToggle">
                            Authentification à deux facteurs (MFA)
                        </label>
                    </div>
                    <small class="mfa-status">
                        @if (currentMfaEnabled)
                        {
                            <span class="status-active">✓ MFA activé - Votre compte est protégé</span>
                        }
                        else
                        {
                            <span class="status-inactive">⚠️ MFA désactivé - Activez-le pour plus de sécurité</span>
                        }
                    </small>
                </div>

                <!-- Section changement de mot de passe -->
                <div class="password-section">
                    <p class="text-muted">
                        Pour changer votre mot de passe, utilisez la page dédiée.
                    </p>
                    <button type="button" 
                            class="btn btn-outline-secondary btn-block"
                            @onclick="NavigateToChangePassword"
                            disabled="@isSaving">
                        🔑 Changer mon mot de passe
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-danger">
                Impossible de charger votre profil. Veuillez vous reconnecter.
            </div>
        }
    </div>
</div>

<!-- ✅ Modale Setup MFA (Enable avec QR Code) -->
@if (showMfaSetupModal)
{
    <div class="modal-overlay" @onclick="CloseMfaSetupModal">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>Activer l'authentification à deux facteurs</h3>
                <button class="btn-close" @onclick="CloseMfaSetupModal">×</button>
            </div>
            <div class="modal-body">
                <MfaVerification 
                    IsLoading="@isMfaSetupLoading"
                    ErrorMessage="@mfaSetupError"
                    ShowQrCode="true"
                    QrCodeBase64="@mfaQrCode"
                    SecretKey="@mfaSecretKey"
                    PromptMessage="Scannez le QR code puis entrez un code pour confirmer"
                    ShowCancelButton="true"
                    OnMfaCodeSubmit="HandleMfaEnableVerify"
                    OnCancel="CloseMfaSetupModal" />
            </div>
        </div>
    </div>
}

<!-- ✅ Modale Disable MFA (Demande code actuel) -->
@if (showMfaDisableModal)
{
    <div class="modal-overlay" @onclick="CloseMfaDisableModal">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>Désactiver l'authentification à deux facteurs</h3>
                <button class="btn-close" @onclick="CloseMfaDisableModal">×</button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    ⚠️ Attention : Désactiver MFA réduira la sécurité de votre compte.
                </div>
                <MfaVerification 
                    IsLoading="@isMfaDisableLoading"
                    ErrorMessage="@mfaDisableError"
                    ShowQrCode="false"
                    PromptMessage="Pour désactiver MFA, entrez votre code actuel"
                    ShowCancelButton="true"
                    OnMfaCodeSubmit="HandleMfaDisableVerify"
                    OnCancel="CloseMfaDisableModal" />
            </div>
        </div>
    </div>
}

<style>
    /* ... Gardez tous vos styles existants ... */
    
    /* ✅ Ajoutez ces nouveaux styles pour MFA */
