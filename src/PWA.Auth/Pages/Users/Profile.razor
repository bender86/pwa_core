@page "/profile"
@page "/user/profile"
@attribute [Authorize]
@using dto.user.Models
@using PWA.Auth.Models
@using dto.common.Enums
@inject IJSRuntime JS
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject WorldBetApiClient WorldBetApi
@inject IUserService UserService
@inject IMfaService MfaService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Mon profil - MaesAuth</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-4">

    <MudText Typo="Typo.h4" Class="mb-1">
        <MudIcon Icon="@Icons.Material.Filled.Person" Class="me-2" />
        Mon Profil
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Gérer vos informations personnelles
    </MudText>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Class="mt-3" Color="Color.Secondary">Chargement...</MudText>
        </div>
    }
    else if (model == null)
    {
        <MudAlert Severity="Severity.Error">
            Impossible de charger votre profil. Veuillez vous reconnecter.
        </MudAlert>
    }
    else
    {
        <MudGrid Spacing="4">

            <!-- Informations personnelles -->
            <MudItem xs="12">
                <MudPaper Elevation="2" Style="overflow: hidden;">
                    <div style="background: var(--mud-palette-primary); padding: 0.75rem 1rem;">
                        <MudText Typo="Typo.body1" Style="color: white; font-weight: 500;">
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Class="me-2" Size="Size.Small" />
                            Informations personnelles
                        </MudText>
                    </div>
                    <div class="pa-4">
                        <UserForm Mode="FormMode.Edit"
                                  InitialData="@model"
                                  OnSubmit="HandleUpdateProfile"
                                  OnCancel="LoadProfile"
                                  IsLoading="@isSaving"
                                  ErrorMessage="@errorMessage"
                                  ShowAdminOptions="false"
                                  ShowCancelButton="true" />
                    </div>
                </MudPaper>
            </MudItem>

            <!-- Notifications WorldBet -->
            <MudItem xs="12">
                <MudPaper Elevation="2" Style="overflow: hidden;">
                    <div style="background: var(--mud-palette-primary); padding: 0.75rem 1rem;">
                        <MudText Typo="Typo.body1" Style="color: white; font-weight: 500;">
                            <MudIcon Icon="@Icons.Material.Filled.Notifications" Class="me-2" Size="Size.Small" />
                            Notifications WorldBet
                        </MudText>
                    </div>
                    <div class="pa-4">
                        @if (!_notifSupported)
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true">
                                Non disponible dans ce navigateur.<br />
                                Sur iPhone : <strong>Safari → Partager → Sur l'écran d'accueil</strong>
                            </MudAlert>
                        }
                        else if (_notifPermission == "denied")
                        {
                            <MudAlert Severity="Severity.Error" Dense="true">
                                Permission refusée — réactivez les notifications dans les réglages du navigateur.
                            </MudAlert>
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <MudSwitch T="bool"
                                           Value="_notifSubscribed"
                                           ValueChanged="HandleNotifToggle"
                                           Color="Color.Primary"
                                           Disabled="_notifLoading"
                                           Label="@(_notifSubscribed ? "Activées" : "Désactivées")" />
                                @if (_notifLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                }
                            </div>

                            <MudText Typo="Typo.caption"
                                     Color="@(_notifSubscribed ? Color.Success : Color.Warning)">
                                @if (_notifSubscribed)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Class="me-1" />
                                    <span>Rappel automatique 1h avant chaque match non pronostiqué</span>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="me-1" />
                                    <span>Active les rappels pour ne plus rater un pronostic</span>
                                }
                            </MudText>

                            @if (_notifSubscribed)
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Default"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Send"
                                           Disabled="_notifLoading"
                                           OnClick="SendTestNotifAsync"
                                           Class="mt-3">
                                    Envoyer une notif de test
                                </MudButton>
                            }

                            @if (!string.IsNullOrEmpty(_notifMessage))
                            {
                                <MudText Typo="Typo.caption"
                                         Color="@(_notifError ? Color.Error : Color.Success)"
                                         Class="d-block mt-2">
                                    @_notifMessage
                                </MudText>
                            }
                        }
                    </div>
                </MudPaper>
            </MudItem>

            <!-- Sécurité -->
            <MudItem xs="12">
                <MudPaper Elevation="2" Style="overflow: hidden;">
                    <div style="background: var(--mud-palette-primary); padding: 0.75rem 1rem;">
                        <MudText Typo="Typo.body1" Style="color: white; font-weight: 500;">
                            <MudIcon Icon="@Icons.Material.Filled.Security" Class="me-2" Size="Size.Small" />
                            Sécurité
                        </MudText>
                    </div>
                    <div class="pa-4">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <div>
                                <MudText Typo="Typo.body1" Style="font-weight: 500;">
                                    Authentification à deux facteurs (MFA)
                                </MudText>
                                <MudText Typo="Typo.caption"
                                         Color="@(currentMfaEnabled ? Color.Success : Color.Warning)">
                                    @if (currentMfaEnabled)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" Class="me-1" />
                                        <span>Activé — votre compte est protégé</span>
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.ShieldMoon" Size="Size.Small" Class="me-1" />
                                        <span>Désactivé — activez-le pour plus de sécurité</span>
                                    }
                                </MudText>
                            </div>
                            <MudSwitch T="bool"
                                       Value="currentMfaEnabled"
                                       ValueChanged="HandleMfaToggle"
                                       Color="Color.Primary"
                                       Disabled="@isSaving" />
                        </div>

                        <MudDivider Class="my-3" />

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.Key"
                                   OnClick="NavigateToChangePassword"
                                   Disabled="@isSaving">
                            Changer mon mot de passe
                        </MudButton>
                    </div>
                </MudPaper>
            </MudItem>

        </MudGrid>
    }
</MudContainer>

<!-- Modal MFA Setup (Enable) -->
<MudDialog @bind-Visible="showMfaSetupModal"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.PhonelinkLock" Class="me-2" />
            Activer l'authentification à deux facteurs
        </MudText>
    </TitleContent>
    <DialogContent>
        <div class="pa-2">
            <MfaVerification IsLoading="@isMfaSetupLoading"
                             ErrorMessage="@mfaSetupError"
                             ShowQrCode="true"
                             QrCodeBase64="@mfaQrCode"
                             SecretKey="@mfaSecretKey"
                             PromptMessage="Scannez le QR code puis entrez un code pour confirmer"
                             ShowCancelButton="true"
                             OnMfaCodeSubmit="HandleMfaEnableVerify"
                             OnCancel="CloseMfaSetupModal" />
        </div>
    </DialogContent>
</MudDialog>

<!-- Modal MFA Disable -->
<MudDialog @bind-Visible="showMfaDisableModal"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.NoEncryption" Class="me-2" />
            Désactiver l'authentification à deux facteurs
        </MudText>
    </TitleContent>
    <DialogContent>
        <div class="pa-2">
            <MudAlert Severity="Severity.Warning" Class="mb-3">
                Désactiver MFA réduira la sécurité de votre compte.
            </MudAlert>
            <MfaVerification IsLoading="@isMfaDisableLoading"
                             ErrorMessage="@mfaDisableError"
                             ShowQrCode="false"
                             PromptMessage="Pour désactiver MFA, entrez votre code actuel"
                             ShowCancelButton="true"
                             OnMfaCodeSubmit="HandleMfaDisableVerify"
                             OnCancel="CloseMfaDisableModal" />
        </div>
    </DialogContent>
</MudDialog>

@code {
    #region Notifications
    private bool _notifSupported  = false;
    private bool _notifSubscribed = false;
    private bool _notifLoading    = false;
    private string _notifPermission = "default";
    private string? _notifMessage;
    private bool _notifError;
    #endregion

    private UserFormModel? model;
    private bool isLoading = true;
    private bool isSaving = false;
    private string? errorMessage;

    private bool currentMfaEnabled = false;
    private int currentUserId;

    private bool showMfaSetupModal = false;
    private bool isMfaSetupLoading = false;
    private string? mfaSetupError;
    private string? mfaQrCode;
    private string? mfaSecretKey;

    private bool showMfaDisableModal = false;
    private bool isMfaDisableLoading = false;
    private string? mfaDisableError;

    protected override async Task OnInitializedAsync() => await LoadProfile();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadNotifStatusAsync();
        StateHasChanged();
    }

    private async Task LoadProfile()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var currentUser = await UserService.GetCurrentUser();
            if (currentUser != null)
            {
                currentUserId    = currentUser.Id;
                currentMfaEnabled = (bool)currentUser.MfaEnabled;
                model = new UserFormModel
                {
                    Id         = currentUser.Id,
                    FirstName  = currentUser.FirstName ?? "",
                    LastName   = currentUser.LastName ?? "",
                    Email      = currentUser.Email,
                    MfaEnabled = (bool)currentUser.MfaEnabled
                };
            }
            else
            {
                errorMessage = "Impossible de charger votre profil";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleUpdateProfile(UserFormModel updatedModel)
    {
        if (updatedModel == null) return;
        isSaving = true;
        errorMessage = null;
        try
        {
            var result = await UserService.UpdateUser(new UpdateUserRequest
            {
                Id        = updatedModel.Id,
                FirstName = updatedModel.FirstName,
                LastName  = updatedModel.LastName,
                Email     = updatedModel.Email,
                Active    = updatedModel.Active
            });

            if (result.Success)
            {
                Snackbar.Add("Profil mis à jour avec succès !", Severity.Success);
                await LoadProfile();
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Erreur lors de la mise à jour";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task HandleMfaToggle(bool newValue)
    {
        if (newValue && !currentMfaEnabled)
            await InitiateMfaSetup();
        else if (!newValue && currentMfaEnabled)
            InitiateMfaDisable();
    }

    private async Task InitiateMfaSetup()
    {
        isMfaSetupLoading = true;
        mfaSetupError = null;
        try
        {
            var result = await MfaService.SetupMfa(currentUserId);
            if (result.Success && result.Data != null)
            {
                mfaQrCode     = result.Data.QrCodeBase64;
                mfaSecretKey  = result.Data.SecretKey;
                showMfaSetupModal = true;
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Erreur lors de l'initialisation MFA";
            }
        }
        catch (Exception ex) { errorMessage = $"Erreur : {ex.Message}"; }
        finally { isMfaSetupLoading = false; }
    }

    private async Task HandleMfaEnableVerify(string code)
    {
        isMfaSetupLoading = true;
        mfaSetupError = null;
        try
        {
            var result = await MfaService.EnableMfa(currentUserId, code);
            if (result.Success)
            {
                currentMfaEnabled = true;
                Snackbar.Add("MFA activé avec succès !", Severity.Success);
                CloseMfaSetupModal();
                await LoadProfile();
            }
            else
            {
                mfaSetupError = result.ErrorMessage ?? "Code invalide";
            }
        }
        catch (Exception ex) { mfaSetupError = $"Erreur : {ex.Message}"; }
        finally { isMfaSetupLoading = false; }
    }

    private void CloseMfaSetupModal()
    {
        showMfaSetupModal = false;
        mfaSetupError = null;
        mfaQrCode = null;
        mfaSecretKey = null;
    }

    private void InitiateMfaDisable()
    {
        showMfaDisableModal = true;
        mfaDisableError = null;
    }

    private async Task HandleMfaDisableVerify(string code)
    {
        isMfaDisableLoading = true;
        mfaDisableError = null;
        try
        {
            var result = await MfaService.DisableMfa(currentUserId, code);
            if (result.Success)
            {
                currentMfaEnabled = false;
                Snackbar.Add("MFA désactivé avec succès", Severity.Info);
                CloseMfaDisableModal();
                await LoadProfile();
            }
            else
            {
                mfaDisableError = result.ErrorMessage ?? "Code invalide";
            }
        }
        catch (Exception ex) { mfaDisableError = $"Erreur : {ex.Message}"; }
        finally { isMfaDisableLoading = false; }
    }

    private void CloseMfaDisableModal()
    {
        showMfaDisableModal = false;
        mfaDisableError = null;
    }

    #region Notifications
    private async Task LoadNotifStatusAsync()
    {
        try { _notifSupported = await JS.InvokeAsync<bool>("eval", "'Notification' in window && 'serviceWorker' in navigator"); }
        catch { _notifSupported = false; }

        if (!_notifSupported) return;

        try { _notifPermission = await JS.InvokeAsync<string>("getNotificationPermission"); }
        catch { _notifPermission = "default"; }

        if (_notifPermission == "granted")
        {
            try
            {
                var status = await WorldBetApi.GetFromJsonAsync<NotifStatus>("notifications/status");
                _notifSubscribed = status?.IsSubscribed ?? false;
            }
            catch { _notifSubscribed = false; }
        }
    }

    private async Task HandleNotifToggle(bool value)
    {
        _notifLoading = true;
        _notifMessage = null;
        try
        {
            if (value)
            {
                var token      = await LocalStorage.GetItemAsync<string>("authToken");
                var apiBaseUrl = await WorldBetApi.GetBaseUrlAsync();
                var result     = await JS.InvokeAsync<SubscribeResult>("subscribeToPush", apiBaseUrl, token);

                if (result.Success)
                {
                    _notifSubscribed = true;
                    _notifPermission = "granted";
                    _notifMessage    = "Notifications activées !";
                    _notifError      = false;
                }
                else
                {
                    _notifPermission = await JS.InvokeAsync<string>("getNotificationPermission");
                    _notifMessage    = result.Error ?? "Erreur lors de l'activation";
                    _notifError      = true;
                }
            }
            else
            {
                await WorldBetApi.DeleteAsync("notifications/unsubscribe");
                _notifSubscribed = false;
                _notifMessage    = "Notifications désactivées.";
                _notifError      = false;
            }
        }
        catch (Exception ex) { _notifMessage = ex.Message; _notifError = true; }
        finally { _notifLoading = false; }
    }

    private async Task SendTestNotifAsync()
    {
        _notifLoading = true;
        _notifMessage = null;
        try
        {
            var response = await WorldBetApi.PostAsync("notifications/test");
            _notifMessage = response.IsSuccessStatusCode
                ? "Notif envoyée ! Tu devrais la recevoir dans quelques secondes."
                : $"Erreur {(int)response.StatusCode}";
            _notifError = !response.IsSuccessStatusCode;
        }
        catch (Exception ex) { _notifMessage = ex.Message; _notifError = true; }
        finally { _notifLoading = false; }
    }

    private record NotifStatus(bool IsSubscribed);
    private record SubscribeResult(bool Success, string? Error);
    #endregion

    private void NavigateToChangePassword() => Navigation.NavigateTo("/change-password");
}