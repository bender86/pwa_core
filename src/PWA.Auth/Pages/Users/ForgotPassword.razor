@* Pages/ForgotPassword.razor *@
@page "/forgot-password"
@using dto.user.Models
@attribute [AllowAnonymous]
@inject IUserService UserService
@inject NavigationManager Navigation

<PageTitle>Mot de passe oublié - MaesAuth</PageTitle>

<div class="forgot-page">
    <MudPaper Elevation="3" Class="forgot-card pa-6">

        @if (step == ForgotPasswordStep.EnterEmail)
        {
            <div class="text-center mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Key"
                         Color="Color.Primary"
                         Style="font-size: 3.5rem;" />
                <MudText Typo="Typo.h5" Class="mt-3 mb-1">Mot de passe oublié ?</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Saisissez votre adresse email pour recevoir un lien de réinitialisation
                </MudText>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
            }

            <MudForm @ref="form" @bind-IsValid="isValid">
                <MudTextField T="string"
                              @bind-Value="email"
                              Label="Adresse email"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="L'email est requis"
                              Validation="@(new Func<string, string?>(ValidateEmail))"
                              Disabled="@isLoading"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email"
                              InputType="InputType.Email"
                              Class="mb-4" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Disabled="@(!isValid || isLoading)"
                           OnClick="HandleEmailSubmit"
                           Class="mb-3">
                    @if (isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                        <span>Envoi en cours...</span>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Send" Class="me-2" />
                        <span>Envoyer le lien</span>
                    }
                </MudButton>

                <div class="text-center">
                    <MudLink Href="/login" Typo="Typo.body2">
                        <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Class="me-1" />
                        Retour à la connexion
                    </MudLink>
                </div>
            </MudForm>
        }
        else
        {
            <div class="text-center">
                <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead"
                         Color="Color.Success"
                         Style="font-size: 4rem;" />
                <MudText Typo="Typo.h5" Class="mt-3 mb-2">Vérifiez vos emails</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                    Un lien de réinitialisation a été envoyé à <strong>@email</strong>
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-5">
                    Le lien expire dans 1 heure. Si vous ne recevez pas l'email, vérifiez vos spams.
                </MudText>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="@(() => Navigation.NavigateTo("/login"))">
                    Retour à la connexion
                </MudButton>
            </div>
        }

    </MudPaper>
</div>

@code {
    private MudForm? form;
    private bool isValid;
    private bool isLoading = false;
    private string email = string.Empty;
    private string? errorMessage;
    private ForgotPasswordStep step = ForgotPasswordStep.EnterEmail;

    private string? ValidateEmail(string value)
    {
        if (string.IsNullOrEmpty(value)) return "L'email est requis";
        if (!value.Contains('@')) return "Adresse email invalide";
        return null;
    }

    private async Task HandleEmailSubmit()
    {
        if (form != null) await form.Validate();
        if (!isValid) return;

        isLoading = true;
        errorMessage = null;
        try
        {
            var response = await UserService.RequestPasswordReset(email);
            if (response.Success)
                step = ForgotPasswordStep.EmailSent;
            else
                errorMessage = response.ErrorMessage ?? "Échec de l'envoi du lien";
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private enum ForgotPasswordStep { EnterEmail, EmailSent }
}

<style>
    .forgot-page {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 1rem;
    }

    .forgot-card {
        width: 100%;
        max-width: 440px;
        border-radius: 12px;
        animation: slideUp 0.4s ease-out;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>