@page "/worldbet/leaderboard"
@using PWA.Auth.Pages.WorldBet.Shared
@using dto.worldbet.Models
@layout WorldBetLayout
@inject ILeaderboardService LeaderboardService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@attribute [Authorize]

<PageTitle>Classement</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">🏆 Classement Général</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
        Les meilleurs pronostiqueurs du tournoi
    </MudText>

    @if (isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }
    else if (!leaderboard.Any())
    {
        <MudAlert Severity="Severity.Info" Class="mb-4">
            Aucun joueur n'a encore marqué de points.
        </MudAlert>
    }
    else
    {
        <!-- Podium (Top 3) -->
        @if (leaderboard.Count >= 3)
        {
            <MudPaper Class="pa-6 mb-6" Elevation="3" Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <MudGrid Justify="Justify.Center" Spacing="3">
                    <!-- 2nd Place -->
                    <MudItem xs="12" sm="4" Class="d-flex flex-column align-center">
                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" 
                                 Size="Size.Large" 
                                 Style="color: #c0c0c0; font-size: 3rem;" 
                                 Class="mb-2" />
                        <MudPaper Class="pa-4 text-center" Style="width: 100%; max-width: 280px;">
                            <MudAvatar Size="Size.Large" 
                                      Color="Color.Secondary" 
                                      Style="width: 80px; height: 80px; font-size: 1.5rem; margin: 0 auto;">
                                @GetInitials(leaderboard[1].DisplayName)
                            </MudAvatar>
                            <MudText Typo="Typo.h6" Class="mt-3 mb-2">
                                <MudLink Href="@GetPlayerLink(leaderboard[1].PlayerId)" Color="Color.Dark">
                                    @leaderboard[1].DisplayName
                                </MudLink>
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.EmojiEvents">
                                @leaderboard[1].TotalPoints pts
                            </MudChip>
                            <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Adjust" Color="Color.Success">
                                @leaderboard[1].CorrectScores exacts
                            </MudChip>
                        </MudPaper>
                        <MudPaper Class="pa-3 mt-2 text-center" 
                                 Style="background: #c0c0c0; width: 100%; max-width: 280px; font-weight: bold; font-size: 1.5rem;">
                            2
                        </MudPaper>
                    </MudItem>

                    <!-- 1st Place -->
                    <MudItem xs="12" sm="4" Class="d-flex flex-column align-center" Style="order: -1;">
                        <MudIcon Icon="@Icons.Material.Filled.Diamond" 
                                 Size="Size.Large" 
                                 Style="color: #ffd700; font-size: 3rem;" 
                                 Class="mb-2 podium-crown" />
                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" 
                                 Size="Size.Large" 
                                 Style="color: #ffd700; font-size: 3rem;" 
                                 Class="mb-2" />
                        <MudPaper Class="pa-4 text-center" Style="width: 100%; max-width: 280px; border: 4px solid #ffd700;">
                            <MudAvatar Size="Size.Large" 
                                      Color="Color.Warning" 
                                      Style="width: 100px; height: 100px; font-size: 2rem; margin: 0 auto; box-shadow: 0 0 20px rgba(255, 215, 0, 0.5);">
                                @GetInitials(leaderboard[0].DisplayName)
                            </MudAvatar>
                            <MudText Typo="Typo.h5" Class="mt-3 mb-2">
                                <MudLink Href="@GetPlayerLink(leaderboard[0].PlayerId)" Color="Color.Dark">
                                    @leaderboard[0].DisplayName
                                </MudLink>
                            </MudText>
                            <MudChip T="string" Size="Size.Medium" Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Warning">
                                @leaderboard[0].TotalPoints pts
                            </MudChip>
                            <MudChip T="string" Size="Size.Medium" Icon="@Icons.Material.Filled.Adjust" Color="Color.Success">
                                @leaderboard[0].CorrectScores exacts
                            </MudChip>
                        </MudPaper>
                        <MudPaper Class="pa-4 mt-2 text-center" 
                                 Style="background: #ffd700; width: 100%; max-width: 280px; font-weight: bold; font-size: 1.5rem;">
                            1
                        </MudPaper>
                    </MudItem>

                    <!-- 3rd Place -->
                    <MudItem xs="12" sm="4" Class="d-flex flex-column align-center">
                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" 
                                 Size="Size.Large" 
                                 Style="color: #cd7f32; font-size: 3rem;" 
                                 Class="mb-2" />
                        <MudPaper Class="pa-4 text-center" Style="width: 100%; max-width: 280px;">
                            <MudAvatar Size="Size.Large" 
                                      Color="Color.Default" 
                                      Style="width: 80px; height: 80px; font-size: 1.5rem; margin: 0 auto;">
                                @GetInitials(leaderboard[2].DisplayName)
                            </MudAvatar>
                            <MudText Typo="Typo.h6" Class="mt-3 mb-2">
                                <MudLink Href="@GetPlayerLink(leaderboard[2].PlayerId)" Color="Color.Dark">
                                    @leaderboard[2].DisplayName
                                </MudLink>
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.EmojiEvents">
                                @leaderboard[2].TotalPoints pts
                            </MudChip>
                            <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Adjust" Color="Color.Success">
                                @leaderboard[2].CorrectScores exacts
                            </MudChip>
                        </MudPaper>
                        <MudPaper Class="pa-3 mt-2 text-center" 
                                 Style="background: #cd7f32; width: 100%; max-width: 280px; font-weight: bold; font-size: 1.5rem;">
                            3
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        }

        <!-- My Ranking Card -->
        @if (currentPlayerRanking != null)
        {
            <MudPaper Class="pa-4 mb-4" 
                     Elevation="3" 
                     Style="@(currentPlayerRanking.Rank <= 3 ? "border: 3px solid #ffd700;" : "")">
                <MudGrid>
                    <MudItem xs="12">
                        <MudText Typo="Typo.h6" Class="mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Class="me-2" />
                            Votre Classement
                        </MudText>
                    </MudItem>
                    <MudItem xs="12" sm="3" Class="text-center">
                        <MudText Typo="Typo.h3" Color="Color.Primary">
                            #@currentPlayerRanking.Rank
                        </MudText>
                        @if (currentPlayerRanking.Rank <= 3)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Warning" Size="Size.Large" />
                        }
                    </MudItem>
                    <MudItem xs="12" sm="9">
                        <MudGrid Spacing="2">
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.h5" Color="Color.Primary">@currentPlayerRanking.TotalPoints</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Points</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.h5" Color="Color.Primary">@currentPlayerRanking.PronosticsCount</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Pronostics</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.h5" Color="Color.Success">@currentPlayerRanking.CorrectScores</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Scores exacts</MudText>
                            </MudItem>
                            <MudItem xs="6" sm="3">
                                <MudText Typo="Typo.h5" Color="Color.Info">@GetSuccessRate(currentPlayerRanking).ToString("F1")%</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Taux de réussite</MudText>
                            </MudItem>
                        </MudGrid>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        }

        <!-- Full Leaderboard Table -->
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h5" Class="mb-4">Classement Complet</MudText>
            
            <MudDataGrid T="LeaderboardDto" 
                        Items="@leaderboard" 
                        Dense="true" 
                        Hover="true"
                        Bordered="true" 
                        Striped="true">
                
                <Columns>
                    <!-- Rank -->
                    <PropertyColumn Property="x => x.Rank" Title="Rang" Sortable="false">
                        <CellTemplate>
                            <div class="d-flex align-items-center gap-2">
                                @if (context.Item.Rank <= 3)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" 
                                            Color="@GetRankColor(context.Item.Rank)" 
                                            Size="Size.Small" />
                                }
                                <MudChip T="string" 
                                        Size="Size.Small" 
                                        Color="@GetRankColor(context.Item.Rank)">
                                    #@context.Item.Rank
                                </MudChip>
                            </div>
                        </CellTemplate>
                    </PropertyColumn>

                    <!-- Player -->
                    <TemplateColumn Title="Joueur" Sortable="false">
                        <CellTemplate>
                            <div class="d-flex align-items-center gap-2">
                                <MudAvatar Size="Size.Small" Color="Color.Primary">
                                    @GetInitials(context.Item.DisplayName)
                                </MudAvatar>
                                <MudLink Href="@GetPlayerLink(context.Item.PlayerId)" 
                                        Color="Color.Dark" 
                                        Typo="Typo.body1">
                                    @context.Item.DisplayName
                                </MudLink>
                                @if (IsCurrentPlayer(context.Item))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">Vous</MudChip>
                                }
                            </div>
                        </CellTemplate>
                    </TemplateColumn>

                    <!-- Points -->
                    <PropertyColumn Property="x => x.TotalPoints" Title="Points" Sortable="false">
                        <CellTemplate>
                            <MudText Typo="Typo.body1" Color="Color.Primary">
                                <strong>@context.Item.TotalPoints</strong>
                            </MudText>
                        </CellTemplate>
                    </PropertyColumn>

                    <!-- Pronostics -->
                    <PropertyColumn Property="x => x.PronosticsCount" 
                                   Title="Pronostics" 
                                   Sortable="false" 
                                   Hideable="true" 
                                   Hidden="@(_isSmallScreen)" />

                    <!-- Correct Scores -->
                    <PropertyColumn Property="x => x.CorrectScores" 
                                   Title="Scores exacts" 
                                   Sortable="false"
                                   Hideable="true" 
                                   Hidden="@(_isSmallScreen)">
                        <CellTemplate>
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">
                                @context.Item.CorrectScores
                            </MudChip>
                        </CellTemplate>
                    </PropertyColumn>

                    <!-- Success Rate -->
                    <TemplateColumn Title="Taux de réussite" 
                                   Sortable="false"
                                   Hideable="true" 
                                   Hidden="@(_isSmallScreen)">
                        <CellTemplate>
                            <MudProgressLinear Color="@GetSuccessRateColor(context.Item)" 
                                            Value="@((double)GetSuccessRate(context.Item))" 
                                            Size="Size.Large" 
                                            Rounded="true">
                                <MudText Typo="Typo.body2">
                                    @GetSuccessRate(context.Item).ToString("F1")%
                                </MudText>
                            </MudProgressLinear>
                        </CellTemplate>
                    </TemplateColumn>

                    <!-- Actions -->
                    <TemplateColumn Title="" Sortable="false" Filterable="false">
                        <CellTemplate>
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility" 
                                          Size="Size.Small" 
                                          Color="Color.Primary"
                                          Href="@GetPlayerLink(context.Item.PlayerId)" />
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>

                <PagerContent>
                    <MudDataGridPager T="LeaderboardDto" />
                </PagerContent>
            </MudDataGrid>
        </MudPaper>
    }
</MudContainer>

@code {
    private List<LeaderboardDto> leaderboard = new();
    private LeaderboardDto? currentPlayerRanking;
    private int currentPlayerId = 0;
    private bool isLoading = true;
    private bool _isSmallScreen = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadLeaderboard();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            // Simple check for mobile - could be improved with JS interop
            _isSmallScreen = false; // Set based on window size if needed
        }
    }

    private async Task LoadLeaderboard()
    {
        isLoading = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userIdClaim = user.FindFirst("id")?.Value;
            
            if (int.TryParse(userIdClaim, out int userId))
            {
                currentPlayerId = userId;
            }

            leaderboard = await LeaderboardService.GetLeaderboardAsync();
            currentPlayerRanking = leaderboard.FirstOrDefault(p => p.PlayerId == currentPlayerId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur lors du chargement : {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetInitials(string displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
            return "??";

        var parts = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        
        return displayName.Length >= 2 
            ? displayName.Substring(0, 2).ToUpper() 
            : displayName.ToUpper();
    }

    private Color GetRankColor(int rank) => rank switch
    {
        1 => Color.Warning,
        2 => Color.Default,
        3 => Color.Default,
        _ => Color.Default
    };

    private Color GetSuccessRateColor(LeaderboardDto player)
    {
        var rate = GetSuccessRate(player);
        return rate switch
        {
            >= 75 => Color.Success,
            >= 50 => Color.Info,
            >= 25 => Color.Warning,
            _ => Color.Error
        };
    }

    private decimal GetSuccessRate(LeaderboardDto player)
    {
        if (player.PronosticsCount == 0)
            return 0;

        return Math.Round((decimal)(player.CorrectScores + player.CorrectWinners) / player.PronosticsCount * 100, 1);
    }

    private bool IsCurrentPlayer(LeaderboardDto player)
    {
        return player.PlayerId == currentPlayerId;
    }

    private string GetPlayerLink(int playerId)
    {
        return $"/worldbet/player/{playerId}";
    }
}

<style>
    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    .podium-crown {
        animation: bounce 2s infinite;
    }

    @@media (min-width: 600px) {
        .mud-grid-item:first-child {
            order: 2 !important;
        }
    }
</style>