@page "/worldbet/rules"
@layout WorldBetLayout
@attribute [Authorize]

<PageTitle>Règlement — WorldBet 2026</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4 mb-8">

    <!-- Header -->
    <MudText Typo="Typo.h4" Class="mb-1">
        <MudIcon Icon="@Icons.Material.Filled.Gavel" Class="me-2" />
        Règlement
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        WorldBet 2026 — Coupe du Monde USA · Canada · Mexique
    </MudText>

    <!-- Inscription & Cagnotte -->
    <MudPaper Elevation="2" Class="pa-5 mb-4">
        <MudText Typo="Typo.h6" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.EuroSymbol" Class="me-2" Color="Color.Warning" />
            Inscription &amp; Cagnotte
        </MudText>
        <MudDivider Class="mb-3" />
        <MudText Class="mb-3">
            La participation est de <strong>10 € par joueur</strong>. L'intégralité des frais d'inscription constitue la cagnotte finale, redistribuée aux trois meilleurs pronostiqueurs à l'issue du tournoi.
        </MudText>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="0" Class="pa-4 text-center" Style="background: linear-gradient(135deg, #ffd700, #ffb300); border-radius: 10px;">
                    <MudText Typo="Typo.h4" Style="color: white;">🥇 50%</MudText>
                    <MudText Typo="Typo.body1" Style="color: white; font-weight: 600;">1er place</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="0" Class="pa-4 text-center" Style="background: linear-gradient(135deg, #c0c0c0, #9e9e9e); border-radius: 10px;">
                    <MudText Typo="Typo.h4" Style="color: white;">🥈 30%</MudText>
                    <MudText Typo="Typo.body1" Style="color: white; font-weight: 600;">2ème place</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="0" Class="pa-4 text-center" Style="background: linear-gradient(135deg, #cd7f32, #a0522d); border-radius: 10px;">
                    <MudText Typo="Typo.h4" Style="color: white;">🥉 20%</MudText>
                    <MudText Typo="Typo.body1" Style="color: white; font-weight: 600;">3ème place</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
        <MudAlert Severity="Severity.Info" Class="mt-3" Dense="true">
            Exemple : 12 joueurs = cagnotte de 120 € → 1er : 60 €, 2ème : 36 €, 3ème : 24 €
        </MudAlert>
    </MudPaper>

    <!-- Système de points -->
    <MudPaper Elevation="2" Class="pa-5 mb-4">
        <MudText Typo="Typo.h6" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.Bolt" Class="me-2" Color="Color.Primary" />
            Système de Points
        </MudText>
        <MudDivider Class="mb-3" />

        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12" sm="6">
                <MudPaper Elevation="0" Class="pa-4" Style="border: 2px solid #4caf50; border-radius: 10px;">
                    <div class="d-flex align-center gap-3">
                        <MudAvatar Color="Color.Success" Size="Size.Large">
                            <MudText Typo="Typo.h5" Style="color:white; font-weight: bold;">3</MudText>
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body1"><strong>Score exact</strong></MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Tu pronostiques 2-1, le résultat est 2-1</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudPaper Elevation="0" Class="pa-4" Style="border: 2px solid #ff9800; border-radius: 10px;">
                    <div class="d-flex align-center gap-3">
                        <MudAvatar Color="Color.Warning" Size="Size.Large">
                            <MudText Typo="Typo.h5" Style="color:white; font-weight: bold;">1</MudText>
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body1"><strong>Bon vainqueur</strong></MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Tu pronostiques 2-1, le résultat est 3-1</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudPaper Elevation="0" Class="pa-4" Style="border: 2px solid #f44336; border-radius: 10px;">
                    <div class="d-flex align-center gap-3">
                        <MudAvatar Color="Color.Error" Size="Size.Large">
                            <MudText Typo="Typo.h5" Style="color:white; font-weight: bold;">0</MudText>
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body1"><strong>Mauvais vainqueur</strong></MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Tu pronostiques 2-1, le résultat est 1-2</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudPaper Elevation="0" Class="pa-4" Style="border: 2px solid #9e9e9e; border-radius: 10px;">
                    <div class="d-flex align-center gap-3">
                        <MudAvatar Color="Color.Default" Size="Size.Large">
                            <MudIcon Icon="@Icons.Material.Filled.MilitaryTech" />
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body1"><strong>Départage</strong></MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">À points égaux, le joueur avec le plus de scores exacts est devant</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- Matches à élimination directe -->
    <MudPaper Elevation="2" Class="pa-5 mb-4">
        <MudText Typo="Typo.h6" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.SportsSoccer" Class="me-2" Color="Color.Error" />
            Matches à Élimination Directe
        </MudText>
        <MudDivider Class="mb-3" />

        <MudAlert Severity="Severity.Warning" Class="mb-4">
            <strong>Important :</strong> En phase éliminatoire, le pronostic porte sur le score à l'issue des <strong>120 minutes</strong> (temps réglementaire + prolongations). Les tirs au but ne sont <strong>pas pris en compte</strong>.
        </MudAlert>

        <MudText Class="mb-4">
            Un match nul après 120' est un résultat valide. Voici comment les points sont attribués :
        </MudText>

        <MudSimpleTable Hover="true" Bordered="true" Dense="true" Class="mb-3">
            <thead>
                <tr>
                    <th>Ton prono</th>
                    <th>Score à 120'</th>
                    <th>Points</th>
                    <th>Raison</th>
                </tr>
            </thead>
            <tbody>
                <tr style="background: #e8f5e9;">
                    <td><strong>2-2</strong></td>
                    <td>2-2 (pen. Équipe A)</td>
                    <td><MudChip T="string" Color="Color.Success" Size="Size.Small">3 pts</MudChip></td>
                    <td>Score exact à 120' ✅</td>
                </tr>
                <tr style="background: #e8f5e9;">
                    <td><strong>3-2</strong></td>
                    <td>3-2 (pen. Équipe B)</td>
                    <td><MudChip T="string" Color="Color.Success" Size="Size.Small">3 pts</MudChip></td>
                    <td>Score exact à 120' ✅</td>
                </tr>
                <tr style="background: #fff8e1;">
                    <td><strong>2-0</strong></td>
                    <td>3-0</td>
                    <td><MudChip T="string" Color="Color.Warning" Size="Size.Small">1 pt</MudChip></td>
                    <td>Bon vainqueur mais score inexact</td>
                </tr>
                <tr style="background: #fff8e1;">
                    <td><strong>1-1</strong></td>
                    <td>2-2 (pen. Équipe A)</td>
                    <td><MudChip T="string" Color="Color.Warning" Size="Size.Small">1 pt</MudChip></td>
                    <td>Bon résultat (nul) mais score inexact</td>
                </tr>
                <tr style="background: #ffebee;">
                    <td><strong>2-1</strong></td>
                    <td>2-2 (pen. Équipe A)</td>
                    <td><MudChip T="string" Color="Color.Error" Size="Size.Small">0 pt</MudChip></td>
                    <td>Mauvais résultat ❌</td>
                </tr>
            </tbody>
        </MudSimpleTable>

        <MudAlert Severity="Severity.Info" Dense="true">
            Le vainqueur aux tirs au but n'a aucune influence sur les points — seul le score à 120' compte.
        </MudAlert>
    </MudPaper>

</MudContainer>