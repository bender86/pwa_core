@page "/worldbet/groups"
@using PWA.Auth.Pages.WorldBet.Shared
@using dto.worldbet.Models
@using dto.worldbet.Enums
@layout WorldBetLayout
@inject ITournamentService TournamentService
@inject IPronosticService PronosticService
@attribute [Authorize]

<PageTitle>Groupes</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.Groups" Class="me-2" />
        Phase de Groupes
    </MudText>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" ShowCloseIcon="true" CloseIconClicked="() => errorMessage = null" Class="mb-4">
            @errorMessage
        </MudAlert>
    }

    @if (isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }
    else if (!groups.Any())
    {
        <MudAlert Severity="Severity.Info">Aucun groupe disponible pour le moment.</MudAlert>
    }
    else
    {
        <!-- Group selector -->

        <MudPaper Class="pa-4 mb-4" Elevation="2">
            <MudSelect T="string"
                    Value="@selectedGroup"
                    ValueChanged="@SelectGroup"
                    Label="Groupe"
                    Variant="Variant.Outlined"
                    Margin="Margin.Dense"
                    Clearable="false"
                    AdornmentIcon="@Icons.Material.Filled.Groups"
                    AdornmentColor="Color.Primary"
                    Style="max-width: 300px;">
                @foreach (var group in groups)
                {
                    <MudSelectItem Value="@group">Groupe @group</MudSelectItem>
                }
            </MudSelect>
        </MudPaper>

        @if (!string.IsNullOrEmpty(selectedGroup))
        {
            <MudGrid Spacing="3">
                <!-- Standings -->
                <MudItem xs="12" lg="5">
                    <MudPaper Elevation="2" Style="overflow: hidden;">
                        <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 1rem 1.5rem;">
                            <MudText Typo="Typo.h6" Style="color: white;">
                                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Class="me-2" />
                                Classement — Groupe @selectedGroup
                            </MudText>
                        </div>

                        @if (isLoadingStandings)
                        {
                            <div class="d-flex justify-content-center pa-4">
                                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                            </div>
                        }
                        else if (!currentStandings.Any())
                        {
                            <MudText Class="pa-4" Color="Color.Secondary">Pas encore de classement.</MudText>
                        }
                        else
                        {
                            <MudSimpleTable Dense="true" Hover="true" Style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th style="width: 40px;">#</th>
                                        <th>Équipe</th>
                                        <th class="text-center" style="width: 30px;">J</th>
                                        <th class="text-center" style="width: 30px;">V</th>
                                        <th class="text-center" style="width: 30px;">N</th>
                                        <th class="text-center" style="width: 30px;">D</th>
                                        <th class="text-center" style="width: 35px;">+/-</th>
                                        <th class="text-center" style="width: 40px; font-weight: 700;">Pts</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var standing in currentStandings)
                                    {
                                        var pos = currentStandings.IndexOf(standing) + 1;
                                        <tr style="@GetRowStyle(pos)">
                                            <td>
                                                <MudChip T="string"
                                                         Size="Size.Small"
                                                         Color="@GetPositionColor(pos)"
                                                         Style="min-width: 28px; justify-content: center;">
                                                    @pos
                                                </MudChip>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    @if (!string.IsNullOrEmpty(standing.FlagUrl))
                                                    {
                                                        <img src="@standing.FlagUrl" alt="@standing.TeamName"
                                                             style="width: 24px; height: 16px; object-fit: cover; border-radius: 2px; flex-shrink: 0;" />
                                                    }
                                                    <MudText Typo="Typo.body2" Style="font-weight: 500;">@standing.TeamName</MudText>
                                                </div>
                                            </td>
                                            <td class="text-center"><MudText Typo="Typo.body2">@standing.Played</MudText></td>
                                            <td class="text-center"><MudText Typo="Typo.body2" Color="Color.Success">@standing.Won</MudText></td>
                                            <td class="text-center"><MudText Typo="Typo.body2" Color="Color.Secondary">@standing.Drawn</MudText></td>
                                            <td class="text-center"><MudText Typo="Typo.body2" Color="Color.Error">@standing.Lost</MudText></td>
                                            <td class="text-center">
                                                <MudText Typo="Typo.body2" Color="@(standing.GoalDifference >= 0 ? Color.Success : Color.Error)">
                                                    @(standing.GoalDifference > 0 ? "+" : "")@standing.GoalDifference
                                                </MudText>
                                            </td>
                                            <td class="text-center">
                                                <MudText Typo="Typo.body2" Style="font-weight: 700;">@standing.Points</MudText>
                                            </td>
                                        </tr>
                                                                            }
                                </tbody>
                            </MudSimpleTable>
                            <div class="pa-3" style="background: var(--mud-palette-background-grey); border-top: 1px solid var(--mud-palette-divider);">
                                <MudText Typo="Typo.caption">
                                    <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small" Color="Color.Success" />
                                    Qualifié &nbsp;
                                    <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small" Color="Color.Default" />
                                    Éliminé
                                </MudText>
                            </div>
                        }
                    </MudPaper>
                </MudItem>

                <!-- Matches -->
                <MudItem xs="12" lg="7">
                    <MudPaper Elevation="2" Style="overflow: hidden;">
                        <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 1rem 1.5rem;">
                            <MudText Typo="Typo.h6" Style="color: white;">
                                <MudIcon Icon="@Icons.Material.Filled.SportsSoccer" Class="me-2" />
                                Matches — Groupe @selectedGroup
                            </MudText>
                        </div>

                        <div class="pa-3">
                            @if (isLoadingMatches)
                            {
                                <div class="d-flex justify-content-center pa-4">
                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                                </div>
                            }
                            else if (!currentMatches.Any())
                            {
                                <MudText Color="Color.Secondary" Class="pa-4 text-center">Aucun match programmé.</MudText>
                            }
                            else
                            {
                                <div class="d-flex flex-column gap-3">
                                    @foreach (var match in currentMatches.OrderBy(m => m.ScheduledDate))
                                    {
                                        var hasProno = userPronostics.TryGetValue(match.MatchId, out var prono);
                                        <MatchCard Match="@match"
                                                   HasPronostic="@hasProno"
                                                   UserPronostic="@prono"
                                                   OnPronosticSaved="@HandlePronosticSaved" />
                                    }
                                </div>
                            }
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    }
</MudContainer>

@code {
    private List<string> groups = new();
    private string selectedGroup = "";
    private List<GroupStandingDto> currentStandings = new();
    private List<MatchDto> currentMatches = new();
    private Dictionary<int, PronosticDto> userPronostics = new();

    private bool isLoading = true;
    private bool isLoadingStandings = false;
    private bool isLoadingMatches = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadGroups();
    }

    private async Task LoadGroups()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var allMatches = await TournamentService.GetAllMatchesAsync();
            groups = allMatches
                .Where(m => !string.IsNullOrEmpty(m.GroupLetter))
                .Select(m => m.GroupLetter!)
                .Distinct()
                .OrderBy(g => g)
                .ToList();

            if (groups.Any())
                await SelectGroup(groups.First());
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement des groupes : {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SelectGroup(string group)
    {
        selectedGroup = group;
        await Task.WhenAll(LoadStandings(), LoadMatches(), LoadPronostics());
    }

    private async Task LoadStandings()
    {
        isLoadingStandings = true;
        try
        {
            currentStandings = await TournamentService.GetGroupStandingsAsync(selectedGroup);
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur classement : {ex.Message}";
        }
        finally
        {
            isLoadingStandings = false;
        }
    }

    private async Task LoadMatches()
    {
        isLoadingMatches = true;
        try
        {
            currentMatches = await TournamentService.GetGroupMatchesAsync(selectedGroup);
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur matches : {ex.Message}";
        }
        finally
        {
            isLoadingMatches = false;
        }
    }

    private async Task LoadPronostics()
    {
        try
        {
            var pronostics = await PronosticService.GetMyPronosticsAsync();
            userPronostics = pronostics.ToDictionary(p => p.MatchId, p => p);
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur pronostics : {ex.Message}";
        }
    }

    private async Task HandlePronosticSaved(PronosticDto prono)
    {
        userPronostics[prono.MatchId] = prono;
        await InvokeAsync(StateHasChanged);
    }

    private Color GetPositionColor(int pos) => pos <= 2 ? Color.Success : Color.Default;

    private string GetRowStyle(int pos) => pos <= 2
        ? "background: rgba(76, 175, 80, 0.08);"
        : "";
}