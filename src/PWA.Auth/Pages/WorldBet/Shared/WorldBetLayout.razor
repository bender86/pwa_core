@inherits LayoutComponentBase
@layout MainLayout
@inject IJSRuntime JSRuntime
@inject ITournamentService TournamentService
@implements IAsyncDisposable

<div class="worldbet-header">
    <div class="badge-container d-none d-sm-flex">
        <div class="trophy-icon"><i class="bi bi-trophy-fill"></i></div>
        <div class="title-group">
            <h2>WorldBet</h2>
            <span class="year">2026</span>
        </div>
    </div>
    <WorldBetNavigation />
    
    <div class="worldbet-content">
        @Body
    </div>
</div>

@code {
    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<WorldBetLayout>? _dotNetRef;
    private Timer? _refreshTimer;

    // Event pour notifier les pages enfants qu'il faut rafraîchir
    public static event Func<Task>? OnRefreshRequested;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialiser pull-to-refresh
            _dotNetRef = DotNetObjectReference.Create(this);
            _jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./js/pwaUtils.js");
            await _jsModule.InvokeVoidAsync("initPullToRefresh", _dotNetRef);

            // Auto-refresh toutes les 30 secondes
            _refreshTimer = new Timer(async _ =>
            {
                await CheckAndRefresh();
            }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
        }
    }

    // Appelé par le JS quand on tire vers le bas
    [JSInvokable]
    public async Task OnPullToRefresh()
    {
        Console.WriteLine("🔄 Pull to refresh triggered!");
        await TriggerRefresh();
    }

    // Vérifie si un match vient de commencer
    private async Task CheckAndRefresh()
    {
        try
        {
            var now = DateTime.UtcNow;
            var upcoming = await TournamentService.GetUpcomingMatchesAsync(10);

            bool matchJustStarted = upcoming.Any(m =>
                m.ScheduledDate <= now &&
                m.ScheduledDate >= now.AddMinutes(-6));

            if (matchJustStarted)
            {
                Console.WriteLine("🔄 Auto-refresh: match just started!");
                await TriggerRefresh();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ CheckAndRefresh error: {ex.Message}");
        }
    }

    private async Task TriggerRefresh()
    {
        if (OnRefreshRequested != null)
        {
            await InvokeAsync(async () =>
            {
                await OnRefreshRequested.Invoke();
                StateHasChanged();
            });
        }
    }

    public async ValueTask DisposeAsync()
    {
        _refreshTimer?.Dispose();
        _dotNetRef?.Dispose();

        if (_jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("disposePullToRefresh");
            await _jsModule.DisposeAsync();
        }
    }
}

<style>
    .worldbet-header {
        padding: 2rem 1rem 1rem;
        text-align: center;
        background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
        color: white;
        border-radius: 0 0 20px 20px;
    }
    
    .badge-container {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
    }

    .worldbet-content {
        padding: 2rem 1rem;
    }
    
    .trophy-icon {
        font-size: 3rem;
        animation: bounce 2s infinite;
    }
    
    .title-group {
        text-align: left;
    }
    
    .title-group h2 {
        margin: 0;
        font-size: 2.5rem;
        font-weight: bold;
        line-height: 1;
    }
    
    .year {
        font-size: 1.5rem;
        color: #ffc107;
        font-weight: bold;
    }
    
    .tagline {
        margin: 0.75rem 0 0 0;
        font-size: 0.95rem;
        opacity: 0.9;
        font-style: italic;
    }
    
    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    @@media (max-width: 768px) {
        .badge-container {
            flex-direction: column;
            gap: 0.5rem;
        }
        
        .title-group {
            text-align: center;
        }
        
        .title-group h2 {
            font-size: 2rem;
        }
        
        .trophy-icon {
            font-size: 2.5rem;
        }
    }
</style>