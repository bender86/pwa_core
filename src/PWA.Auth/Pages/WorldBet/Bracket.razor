@page "/worldbet/bracket"
@using dto.worldbet.Models
@using dto.worldbet.Enums
@using PWA.Auth.Components.worldbet.BracketMatchCard
@layout WorldBetLayout
@inject ITournamentService TournamentService
@inject IPronosticService PronosticService
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@attribute [Authorize]

<PageTitle>Tableau final — WorldBet 2026</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4 px-2">
    <MudText Typo="Typo.h5" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Class="me-2" />
        Tableau de la phase finale
    </MudText>

    @if (isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }
    else
    {
        <div class="bracket-scroll">
            <div class="bracket-wrapper">

                <!-- ===== GAUCHE : 16es → R8 → QF → SF ===== -->
                <div class="bracket-side bracket-left">

                    <!-- 16es gauche (MN 100-108, idx 0-7) -->
                    <div class="bracket-round">
                        <div class="round-label">Seizièmes</div>
                        <div class="round-slots">
                            @for (int i = 0; i < 8; i++)
                            {
                                var idx = i;
                                <div class="bracket-slot">
                                    <BracketMatchCard
                                        Match="@GetR16Match(idx)"
                                        PlaceholderTeam1="@R32Structure[idx].Team1"
                                        PlaceholderTeam2="@R32Structure[idx].Team2"
                                        IsTbd="@IsTbd(idx)"
                                        HasPronostic="@HasProno(GetR16Match(idx)?.MatchId)"
                                        UserPronostic="@GetProno(GetR16Match(idx)?.MatchId)"
                                        OnPronosticSaved="@HandlePronosticSaved"
                                        IsAdmin="@isAdmin"
                                        OnEdit="@HandleEdit"
                                        OnDelete="@HandleDelete" />
                                    <div class="connector-h"></div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- R8 gauche (MN 120-123) -->
                    <div class="bracket-round">
                        <div class="round-label">Huitièmes</div>
                        <div class="round-slots slots-r8">
                            @foreach (var mn in new[]{120, 121, 122, 123})
                            {
                                var m = GetMatchByNumber(mn);
                                <div class="bracket-slot slot-paired">
                                    <div class="connector-h"></div>
                                    <BracketMatchCard
                                        Match="@m"
                                        PlaceholderTeam1="@GetR16Label(GetR16IdxForR8(mn, 0))"
                                        PlaceholderTeam2="@GetR16Label(GetR16IdxForR8(mn, 1))"
                                        IsTbd="@(m == null || IsTbdMatch(m))"
                                        HasPronostic="@HasProno(m?.MatchId)"
                                        UserPronostic="@GetProno(m?.MatchId)"
                                        OnPronosticSaved="@HandlePronosticSaved"
                                        IsAdmin="@isAdmin"
                                        OnEdit="@HandleEdit"
                                        OnDelete="@HandleDelete" />
                                    <div class="connector-h"></div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- QF gauche (MN 130-131) -->
                    <div class="bracket-round">
                        <div class="round-label">Quarts</div>
                        <div class="round-slots slots-qf">
                            @foreach (var mn in new[]{130, 131})
                            {
                                var m = GetMatchByNumber(mn);
                                <div class="bracket-slot slot-paired">
                                    <div class="connector-h"></div>
                                    <BracketMatchCard
                                        Match="@m"
                                        PlaceholderTeam1="@($"V{GetR8PrevLabel(mn, 0)}")"
                                        PlaceholderTeam2="@($"V{GetR8PrevLabel(mn, 1)}")"
                                        IsTbd="@(m == null || IsTbdMatch(m))"
                                        HasPronostic="@HasProno(m?.MatchId)"
                                        UserPronostic="@GetProno(m?.MatchId)"
                                        OnPronosticSaved="@HandlePronosticSaved"
                                        IsAdmin="@isAdmin"
                                        OnEdit="@HandleEdit"
                                        OnDelete="@HandleDelete" />
                                    <div class="connector-h"></div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- SF gauche (MN 140) -->
                    <div class="bracket-round">
                        <div class="round-label">Demi-finales</div>
                        <div class="round-slots slots-sf">
                            @{ var sf140 = GetMatchByNumber(140); }
                            <div class="bracket-slot slot-paired">
                                <div class="connector-h"></div>
                                <BracketMatchCard
                                    Match="@sf140"
                                    PlaceholderTeam1="V130"
                                    PlaceholderTeam2="V131"
                                    IsTbd="@(sf140 == null || IsTbdMatch(sf140))"
                                    HasPronostic="@HasProno(sf140?.MatchId)"
                                    UserPronostic="@GetProno(sf140?.MatchId)"
                                    OnPronosticSaved="@HandlePronosticSaved"
                                    IsAdmin="@isAdmin"
                                    OnEdit="@HandleEdit"
                                    OnDelete="@HandleDelete" />
                                <div class="connector-h"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ===== CENTRE : Finale (143) + 3e place (142) ===== -->
                <div class="bracket-center">
                    <div class="round-label">Finale</div>
                    @{ var finalMatch = GetMatchByNumber(143); }
                    <div class="final-slot">
                        <BracketMatchCard
                            Match="@finalMatch"
                            PlaceholderTeam1="V140"
                            PlaceholderTeam2="V141"
                            IsTbd="@(finalMatch == null || IsTbdMatch(finalMatch))"
                            HasPronostic="@HasProno(finalMatch?.MatchId)"
                            UserPronostic="@GetProno(finalMatch?.MatchId)"
                            OnPronosticSaved="@HandlePronosticSaved"
                            IsHighlighted="true"
                            IsAdmin="@isAdmin"
                            OnEdit="@HandleEdit"
                            OnDelete="@HandleDelete" />
                    </div>

                    @if (!string.IsNullOrEmpty(champion))
                    {
                        <div class="champion-box mt-3">
                            <div class="champion-trophy">🏆</div>
                            <MudText Typo="Typo.h6" Align="Align.Center" Style="font-weight:700;">@champion</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">Champion 2026</MudText>
                        </div>
                    }

                    <div class="third-place-slot mt-4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center" Class="mb-1">3e place</MudText>
                        @{ var thirdMatch = GetMatchByNumber(142); }
                        <BracketMatchCard
                            Match="@thirdMatch"
                            PlaceholderTeam1="P140"
                            PlaceholderTeam2="P141"
                            IsTbd="@(thirdMatch == null || IsTbdMatch(thirdMatch))"
                            HasPronostic="@HasProno(thirdMatch?.MatchId)"
                            UserPronostic="@GetProno(thirdMatch?.MatchId)"
                            OnPronosticSaved="@HandlePronosticSaved"
                            IsAdmin="@isAdmin"
                            OnEdit="@HandleEdit"
                            OnDelete="@HandleDelete" />
                    </div>
                </div>

                <!-- ===== DROITE : SF → QF → R8 → 16es ===== -->
                <div class="bracket-side bracket-right">

                    <!-- SF droite (MN 141) -->
                    <div class="bracket-round">
                        <div class="round-label">Demi-finales</div>
                        <div class="round-slots slots-sf">
                            @{ var sf141 = GetMatchByNumber(141); }
                            <div class="bracket-slot slot-paired">
                                <div class="connector-h"></div>
                                <BracketMatchCard
                                    Match="@sf141"
                                    PlaceholderTeam1="V132"
                                    PlaceholderTeam2="V133"
                                    IsTbd="@(sf141 == null || IsTbdMatch(sf141))"
                                    HasPronostic="@HasProno(sf141?.MatchId)"
                                    UserPronostic="@GetProno(sf141?.MatchId)"
                                    OnPronosticSaved="@HandlePronosticSaved"
                                    IsAdmin="@isAdmin"
                                    OnEdit="@HandleEdit"
                                    OnDelete="@HandleDelete" />
                                <div class="connector-h"></div>
                            </div>
                        </div>
                    </div>

                    <!-- QF droite (MN 132-133) -->
                    <div class="bracket-round">
                        <div class="round-label">Quarts</div>
                        <div class="round-slots slots-qf">
                            @foreach (var mn in new[]{132, 133})
                            {
                                var m = GetMatchByNumber(mn);
                                <div class="bracket-slot slot-paired">
                                    <div class="connector-h"></div>
                                    <BracketMatchCard
                                        Match="@m"
                                        PlaceholderTeam1="@($"V{GetR8PrevLabel(mn, 0)}")"
                                        PlaceholderTeam2="@($"V{GetR8PrevLabel(mn, 1)}")"
                                        IsTbd="@(m == null || IsTbdMatch(m))"
                                        HasPronostic="@HasProno(m?.MatchId)"
                                        UserPronostic="@GetProno(m?.MatchId)"
                                        OnPronosticSaved="@HandlePronosticSaved"
                                        IsAdmin="@isAdmin"
                                        OnEdit="@HandleEdit"
                                        OnDelete="@HandleDelete" />
                                    <div class="connector-h"></div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- R8 droite (MN 124-127) -->
                    <div class="bracket-round">
                        <div class="round-label">Huitièmes</div>
                        <div class="round-slots slots-r8">
                            @foreach (var mn in new[]{124, 125, 126, 127})
                            {
                                var m = GetMatchByNumber(mn);
                                <div class="bracket-slot slot-paired">
                                    <div class="connector-h"></div>
                                    <BracketMatchCard
                                        Match="@m"
                                        PlaceholderTeam1="@GetR16Label(GetR16IdxForR8(mn, 0))"
                                        PlaceholderTeam2="@GetR16Label(GetR16IdxForR8(mn, 1))"
                                        IsTbd="@(m == null || IsTbdMatch(m))"
                                        HasPronostic="@HasProno(m?.MatchId)"
                                        UserPronostic="@GetProno(m?.MatchId)"
                                        OnPronosticSaved="@HandlePronosticSaved"
                                        IsAdmin="@isAdmin"
                                        OnEdit="@HandleEdit"
                                        OnDelete="@HandleDelete" />
                                    <div class="connector-h"></div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- 16es droite (MN 109-117, idx 8-15) -->
                    <div class="bracket-round">
                        <div class="round-label">Seizièmes</div>
                        <div class="round-slots">
                            @for (int i = 8; i < 16; i++)
                            {
                                var idx = i;
                                <div class="bracket-slot">
                                    <div class="connector-h"></div>
                                    <BracketMatchCard
                                        Match="@GetR16Match(idx)"
                                        PlaceholderTeam1="@R32Structure[idx].Team1"
                                        PlaceholderTeam2="@R32Structure[idx].Team2"
                                        IsTbd="@IsTbd(idx)"
                                        HasPronostic="@HasProno(GetR16Match(idx)?.MatchId)"
                                        UserPronostic="@GetProno(GetR16Match(idx)?.MatchId)"
                                        OnPronosticSaved="@HandlePronosticSaved"
                                        IsAdmin="@isAdmin"
                                        OnEdit="@HandleEdit"
                                        OnDelete="@HandleDelete" />
                                </div>
                            }
                        </div>
                    </div>
                </div>

            </div>
        </div>
    }
</MudContainer>

@implements IDisposable
@code {
    private bool isLoading = true;
    private bool isAdmin = false;
    private List<MatchDto> allMatches = new();
    private List<MatchDto> r16Matches = new();
    private Dictionary<int, PronosticDto> userPronostics = new();
    private string? champion;
    private int[] r16MatchNumbers = Array.Empty<int>();

    private const string TbdName = "TBD1";

    private static readonly (string Team1, string Team2)[] R32Structure =
    [
        ("1er Groupe E", "3e A/B/C/D/F"),   // idx 0 → MN 100
        ("1er Groupe I", "3e C/D/F/G/H"),   // idx 1 → MN 101
        ("2e Groupe A",  "2e Groupe B"),     // idx 2 → MN 102
        ("1er Groupe F", "2e Groupe C"),     // idx 3 → MN 104
        ("2e Groupe K",  "2e Groupe L"),     // idx 4 → MN 105
        ("1er Groupe H", "2e Groupe J"),     // idx 5 → MN 106
        ("1er Groupe D", "3e B/E/F/I/J"),   // idx 6 → MN 107
        ("1er Groupe G", "3e A/E/H/I/J"),   // idx 7 → MN 108
        ("1er Groupe C", "2e Groupe F"),     // idx 8  → MN 109
        ("2e Groupe E",  "2e Groupe I"),     // idx 9  → MN 110
        ("1er Groupe A", "3e C/E/F/H/I"),   // idx 10 → MN 111
        ("1er Groupe L", "3e E/H/I/J/K"),   // idx 11 → MN 112
        ("1er Groupe J", "2e Groupe H"),     // idx 12 → MN 114
        ("2e Groupe D",  "2e Groupe G"),     // idx 13 → MN 115
        ("1er Groupe B", "3e E/F/G/I/J"),   // idx 14 → MN 116
        ("1er Groupe K", "3e D/E/I/J/L"),   // idx 15 → MN 117
    ];

    private static readonly Dictionary<int, (int R16a, int R16b)> R8ToR16 = new()
    {
        [120] = (100, 101),
        [121] = (102, 104),
        [122] = (105, 106),
        [123] = (107, 108),
        [124] = (109, 110),
        [125] = (111, 112),
        [126] = (114, 115),
        [127] = (116, 117),
    };

    private static readonly Dictionary<int, (int R8a, int R8b)> QFToR8 = new()
    {
        [130] = (120, 121),
        [131] = (122, 123),
        [132] = (124, 125),
        [133] = (126, 127),
    };

    protected override async Task OnInitializedAsync()
    {
        // Abonnement au refresh du layout
        WorldBetLayout.OnRefreshRequested += RefreshPage;
        var user = await AuthService.GetCurrentUserAsync();
        isAdmin = user?.Admin ?? false;

        await Task.WhenAll(LoadMatches(), LoadPronostics());
    }

    private async Task RefreshPage()
    {
        await Task.WhenAll(LoadMatches(), LoadPronostics());
    }

    public void Dispose()
    {
        WorldBetLayout.OnRefreshRequested -= RefreshPage;
    }
    private async Task LoadMatches()
    {
        isLoading = true;
        try
        {
            allMatches = await TournamentService.GetAllMatchesAsync();

            r16Matches = allMatches
                .Where(m => m.PhaseName == "Round of 16")
                .OrderBy(m => m.MatchNumber)
                .ToList();

            r16MatchNumbers = r16Matches.Select(m => m.MatchNumber).ToArray();
            ComputeChampion();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erreur : {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadPronostics()
    {
        try
        {
            var pronostics = await PronosticService.GetMyPronosticsAsync();
            userPronostics = pronostics.ToDictionary(p => p.MatchId, p => p);
        }
        catch { }
    }

    private void ComputeChampion()
    {
        var final = GetMatchByNumber(143);
        if (final?.Status == MatchStatus.Finished && final.ScoreTeam1.HasValue && final.ScoreTeam2.HasValue)
        {
            champion = final.ScoreTeam1 > final.ScoreTeam2 ? final.Team1Name
                : final.ScoreTeam2 > final.ScoreTeam1 ? final.Team2Name
                : final.PenaltyWinnerTeam == 1 ? final.Team1Name
                : final.Team2Name;
        }
    }

    // ===== Admin handlers =====

    private void HandleEdit(MatchDto match)
        => Navigation.NavigateTo($"/worldbet/admin/matches?edit={match.MatchId}");

    private Task HandleDelete(MatchDto match)
        => LoadMatches(); // Rafraîchit après suppression

    // ===== Helpers =====

    private MatchDto? GetMatchByNumber(int mn)
        => allMatches.FirstOrDefault(m => m.MatchNumber == mn);

    private MatchDto? GetR16Match(int idx)
        => r16Matches.ElementAtOrDefault(idx);

    private bool IsTbd(int idx)
    {
        var m = GetR16Match(idx);
        return m == null || IsTbdMatch(m);
    }

    private bool IsTbdMatch(MatchDto m)
        => m.Team1Name == TbdName || m.Team2Name == TbdName
        || string.IsNullOrEmpty(m.Team1Name) || string.IsNullOrEmpty(m.Team2Name);

    private string GetR16Label(int r16Idx)
    {
        if (r16Idx < 0 || r16Idx >= r16MatchNumbers.Length) return "TBD";
        var mn = r16MatchNumbers[r16Idx];
        return mn > 0 ? $"N°{mn}" : "TBD";
    }

    private int GetR16IdxByMN(int mn)
        => Array.IndexOf(r16MatchNumbers, mn);

    private int GetR16IdxForR8(int r8mn, int pos)
    {
        if (!R8ToR16.TryGetValue(r8mn, out var pair)) return -1;
        return GetR16IdxByMN(pos == 0 ? pair.R16a : pair.R16b);
    }

    private int GetR8PrevLabel(int qfmn, int pos)
    {
        if (!QFToR8.TryGetValue(qfmn, out var pair)) return 0;
        return pos == 0 ? pair.R8a : pair.R8b;
    }

    private bool HasProno(int? matchId)
        => matchId.HasValue && userPronostics.ContainsKey(matchId.Value);

    private PronosticDto? GetProno(int? matchId)
        => matchId.HasValue && userPronostics.TryGetValue(matchId.Value, out var p) ? p : null;

    private async Task HandlePronosticSaved(PronosticDto prono)
    {
        userPronostics[prono.MatchId] = prono;
        await InvokeAsync(StateHasChanged);
    }
}

<style>
    .bracket-scroll {
        overflow-x: auto;
        overflow-y: visible;
        padding-bottom: 2rem;
        -webkit-overflow-scrolling: touch;
    }

    .bracket-wrapper {
        display: flex;
        align-items: center;
        min-width: 1600px;
        padding: 1rem 0.5rem;
        gap: 0;
    }

    .bracket-side {
        display: flex;
        flex-direction: row;
        flex: 1;
    }

    .bracket-round {
        display: flex;
        flex-direction: column;
        min-width: 200px;
        max-width: 220px;
    }

    .round-label {
        text-align: center;
        font-size: 11px;
        font-weight: 600;
        color: var(--mud-palette-text-secondary);
        padding: 0 4px 8px;
        border-bottom: 1px solid var(--mud-palette-divider);
        margin-bottom: 8px;
        white-space: nowrap;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .round-slots {
        display: flex;
        flex-direction: column;
        flex: 1;
        justify-content: space-around;
        gap: 8px;
    }

    .slots-r8 { gap: 16px; }
    .slots-qf { gap: 100px; }
    .slots-sf { gap: 240px; }

    .bracket-slot {
        display: flex;
        align-items: center;
    }

    .slot-paired {
        justify-content: center;
    }

    .connector-h {
        width: 12px;
        height: 2px;
        background: var(--mud-palette-divider);
        flex-shrink: 0;
    }

    .bracket-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-width: 240px;
        padding: 0 8px;
        align-self: center;
    }

    .final-slot {
        width: 100%;
    }

    .third-place-slot {
        width: 100%;
        opacity: 0.85;
        margin-top: 2rem;
    }

    .champion-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        background: linear-gradient(135deg, #ffd700 0%, #ffa500 100%);
        border-radius: 12px;
        padding: 1rem;
        width: 100%;
        margin-top: 1rem;
    }

    .champion-trophy {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
        animation: bounce 2s infinite;
    }

    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
    }
</style>