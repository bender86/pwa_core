@page "/"
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthService AuthService
@using dto.auth.Models
@using dto.common.Models

<PageTitle>Accueil - MaesAuth</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">

    @if (!isAuthenticated)
    {
        <div class="text-center py-5">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Class="mt-3" Color="Color.Secondary">Vérification de l'authentification...</MudText>
        </div>
    }
    else
    {
        <div class="text-center mb-6">
            <MudText Typo="Typo.h4" Style="font-weight: 600;">
                Bienvenue@(!string.IsNullOrEmpty(userName) ? $", {userName}" : "") !
            </MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-1">
                Sélectionnez une application pour continuer
            </MudText>
        </div>

        @if (isLoading)
        {
            <div class="text-center py-5">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Class="mt-3" Color="Color.Secondary">Chargement des applications...</MudText>
            </div>
        }
        else if (availableApps.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="mx-auto" Style="max-width: 600px;">
                Vous n'avez accès à aucune application pour le moment. Contactez votre administrateur.
            </MudAlert>
        }
        else
        {
            <MudGrid Spacing="4" Justify="Justify.Center">
                @foreach (var app in availableApps)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="2"
                                  Class="app-tile pa-6"
                                  @onclick="() => NavigateToApp(app)">
                            <div class="app-icon mb-4">
                                @if (!string.IsNullOrEmpty(app.IconUrl))
                                {
                                    <MudImage Src="@app.IconUrl"
                                              Alt="@app.DisplayName"
                                              Width="48" Height="48"
                                              ObjectFit="ObjectFit.Contain" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Apps"
                                             Color="Color.Primary"
                                             Style="font-size: 3rem;" />
                                }
                            </div>
                            <MudText Typo="Typo.h6" Style="font-weight: 600;">@app.DisplayName</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.ArrowForward"
                                     Color="Color.Primary"
                                     Class="app-arrow mt-2" />
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
    }

</MudContainer>

@code {
    private bool isAuthenticated = false;
    private bool isLoading = true;
    private List<ApplicationDetailsResponse> availableApps = new();
    private string userName = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user?.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/login", replace: true);
            return;
        }

        isAuthenticated = true;
        await LoadUserInfo();
        await LoadApplications();
    }

    private async Task LoadUserInfo()
    {
        try
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user != null)
                userName = string.IsNullOrEmpty(user.FullName) ? user.Email : user.FullName;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading user info: {ex.Message}");
        }
    }

    private async Task LoadApplications()
    {
        isLoading = true;
        try
        {
            availableApps = await AuthService.GetUserApplicationDetailsAsync();

            if (availableApps.Count == 1)
            {
                NavigateToApp(availableApps[0]);
                return;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading applications: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateToApp(ApplicationDetailsResponse app)
    {
        if (string.IsNullOrEmpty(app.AppUrl)) return;

        if (app.AppUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            Navigation.NavigateTo(app.AppUrl, forceLoad: true);
        else
            Navigation.NavigateTo(app.AppUrl);
    }
}

<style>
    .app-tile {
        cursor: pointer;
        border-radius: 12px !important;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .app-tile:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12) !important;
    }

    .app-icon {
        width: 64px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--mud-palette-background-grey);
        border-radius: 12px;
    }

    .app-arrow {
        opacity: 0;
        transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .app-tile:hover .app-arrow {
        opacity: 1;
        transform: translateX(4px);
    }
</style>